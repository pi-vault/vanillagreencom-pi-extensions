	"tokenColors": [
		{
			"name": "Comments",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#8b8795",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Keywords / control",
			"scope": [
				"keyword",
				"storage.modifier",
				"keyword.control",
				"keyword.operator.expression"
			],
			"settings": {
				"foreground": "#177786"
			}
		},
		{
			"name": "Functions / methods",
			"scope": [
				"entity.name.function",
