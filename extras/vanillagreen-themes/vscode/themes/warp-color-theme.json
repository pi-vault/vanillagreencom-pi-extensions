	"tokenColors": [
		{
			"name": "Comments",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#8b8795",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Keywords / control",
			"scope": [
				"keyword",
				"storage.modifier",
				"keyword.control",
				"keyword.operator.expression"
			],
			"settings": {
				"foreground": "#19AAD8"
			}
		},
		{
			"name": "Functions / methods",
			"scope": [
				"entity.name.function",
				"support.function",
				"meta.function-call entity.name.function"
