#!/usr/bin/env bash
# flightdeck-mode — detect Flightdeck-managed linear-orch sessions and
# expose the scoped issue's worktree/branch so cleanup steps can avoid
# destructive prompts about unrelated artifacts.
#
# Detection is tri-state so callers can fail-closed when the answer is
# unknown rather than silently reverting to the broad sweep:
#   managed    — explicit signal present
#   unmanaged  — explicit standalone signal present
#   unknown    — no authoritative signal (treat as managed for safety)
#
# Authoritative signals (in priority order):
#   1. FLIGHTDECK_MANAGED=1   — explicit cross-harness signal set by
#                               skills/flightdeck/scripts/open-terminal
#                               on every spawned issue pane. Always
#                               trusted; this is the safest signal.
#   2. FLIGHTDECK_MANAGED=0   — explicit standalone override.
#   3. FLIGHTDECK_CHILD_PANE=1 — legacy alias set on Pi child panes
#                               before FLIGHTDECK_MANAGED existed.
#
# Best-effort signals (only consulted when explicit signals are absent):
#   4. Master-state file at
#      <main-repo-root>/<FLIGHTDECK_STATE_DIR>/flightdeck-state-<tmux-session>.json
#      lists $PWD as a registered worktree.
#
# When none of the above resolve, mode is `unknown`. Callers that drive
# destructive operations MUST treat `unknown` as managed (skip broad
# sweep) and surface a warning. The `check` subcommand reflects this:
# exits 0 (managed) on both `managed` and `unknown`; exits 1 only on
# `unmanaged`.
#
# Subcommands:
#   check                  exit 0 if managed or unknown, 1 only when unmanaged
#   mode                   print one of: managed | unmanaged | unknown
#   scope-json             print {"mode":..,"issue_id":..,"worktree":..,"branch":..}
#   current-issue          print scoped issue id
#   current-worktree       print scoped worktree absolute path
#   current-branch         print scoped branch name
#   match-branch <name>    exit 0 if <name> equals scoped branch
#   match-worktree <path>  exit 0 if <path> resolves to scoped worktree
#
# Flags (apply to scope subcommands and match-*):
#   --issue <ID>           Force scope lookup to the named issue's
#                          workflow-state file. Required when callers
#                          may run from a directory other than the
#                          worktree (e.g. main repo). Without it, the
#                          helper picks the newest workflow-state-*.json
#                          in the current repo's $ORCH_STATE_DIR, which
#                          can be the wrong file if multiple worktrees
#                          live there.
#
# Architecture note: this script reads .issues directly via jq. When the
# flightdeck session-management reframe lands (see
# docs/plans/flightdeck-session-management-reframe.md), a normalized
# read seam should replace the direct field access.
#
# Exit code 2 = bad arguments.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

ISSUE_ARG=""

resolve_main_repo_root() {
  local common_dir
  common_dir=$(git rev-parse --git-common-dir 2>/dev/null || true)
  [[ -z "$common_dir" ]] && return 1
  if [[ "$common_dir" == ".git" ]]; then
    git rev-parse --show-toplevel 2>/dev/null
  else
    sed 's|/\.git$||' <<<"$common_dir"
  fi
}

# Locate the linear-orch workflow-state file for the scoped issue.
# When --issue was given, look for workflow-state-<ID>.json across both
# the current repo and the main-repo-root (callers like merge-pr.md cd
# into the main repo before invoking us). When no --issue was given,
# pick the newest workflow-state-*.json in the current repo's state dir
# as a best-effort fallback.
resolve_workflow_state_file() {
  local state_dir="${ORCH_STATE_DIR:-tmp}"
  local roots=()
  local cwd_root
  cwd_root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
  roots+=("$cwd_root")
  local main_root
  if main_root=$(resolve_main_repo_root 2>/dev/null); then
    if [[ "$main_root" != "$cwd_root" ]]; then
      roots+=("$main_root")
    fi
  fi

  if [[ -n "$ISSUE_ARG" ]]; then
    local r f
    for r in "${roots[@]}"; do
      f="$r/$state_dir/workflow-state-$ISSUE_ARG.json"
      if [[ -f "$f" ]]; then
        printf '%s' "$f"
        return 0
      fi
    done
    return 1
  fi

  # No --issue: best-effort newest workflow-state file in the current
  # repo's state dir. Do NOT cross into the main repo here — there are
  # often many siblings and the newest is meaningless.
  local dir="$cwd_root/$state_dir"
  [[ -d "$dir" ]] || return 1
  local newest=""
  while IFS= read -r -d '' f; do
    if [[ -z "$newest" || "$f" -nt "$newest" ]]; then
      newest="$f"
    fi
  done < <(find "$dir" -maxdepth 1 -name 'workflow-state-*.json' -print0 2>/dev/null)
  [[ -n "$newest" ]] && printf '%s' "$newest"
}

resolve_master_state_file() {
  local main_root state_dir session_name
  main_root=$(resolve_main_repo_root) || return 1
  state_dir="${FLIGHTDECK_STATE_DIR:-tmp}"
  session_name=$(tmux display-message -p '#S' 2>/dev/null || true)
  [[ -z "$session_name" ]] && return 1
  local f="$main_root/$state_dir/flightdeck-state-$session_name.json"
  [[ -f "$f" ]] || return 1
  printf '%s' "$f"
}

current_pwd_abs() {
  cd "$PWD" 2>/dev/null && pwd
}

# Returns 0/1/2 for managed/unmanaged/unknown via global $MODE_RESULT.
detect_mode() {
  MODE_RESULT="unknown"

  if [[ "${FLIGHTDECK_MANAGED:-}" == "1" ]]; then
    MODE_RESULT="managed"; return 0
  fi
  if [[ "${FLIGHTDECK_MANAGED:-}" == "0" ]]; then
    MODE_RESULT="unmanaged"; return 0
  fi
  if [[ "${FLIGHTDECK_CHILD_PANE:-}" == "1" ]]; then
    MODE_RESULT="managed"; return 0
  fi

  # Best-effort: master-state file lists this worktree.
  if command -v jq >/dev/null 2>&1; then
    local state_file cwd
    if state_file=$(resolve_master_state_file 2>/dev/null) && [[ -n "$state_file" ]]; then
      cwd=$(current_pwd_abs)
      # TODO(reframe-phase-1): consume via TrackedEntry seam once available.
      if [[ -n "$cwd" ]] && jq -e --arg p "$cwd" \
        '(.issues // {}) | to_entries | any(.value.worktree == $p)' \
        "$state_file" >/dev/null 2>&1; then
        MODE_RESULT="managed"; return 0
      fi
    fi
  fi

  # No authoritative signal — leave as `unknown`. Caller decides.
  MODE_RESULT="unknown"
  return 0
}

scope_issue_id() {
  if [[ -n "$ISSUE_ARG" ]]; then
    printf '%s' "$ISSUE_ARG"
    return 0
  fi
  local wf id
  if wf=$(resolve_workflow_state_file 2>/dev/null) && [[ -f "$wf" ]]; then
    id=$(jq -r '.issue_id // empty' "$wf" 2>/dev/null || true)
    if [[ -n "$id" ]]; then
      printf '%s' "$id"
      return 0
    fi
  fi
  local branch pat
  branch=$(git branch --show-current 2>/dev/null || true)
  pat="${GH_ISSUE_PATTERN:-[A-Z]+-[0-9]+}"
  if [[ -n "$branch" ]]; then
    printf '%s' "$branch" | grep -oiE "$pat" | head -1 | tr '[:lower:]' '[:upper:]' || true
  fi
}

scope_worktree() {
  local wf p
  if wf=$(resolve_workflow_state_file 2>/dev/null) && [[ -f "$wf" ]]; then
    p=$(jq -r '.worktree // empty' "$wf" 2>/dev/null || true)
    if [[ -n "$p" ]]; then
      printf '%s' "$p"
      return 0
    fi
  fi
  # No --issue and no workflow-state: fall back to $PWD only when the
  # caller did not name an issue. With --issue we refuse to guess.
  # Always return 0 so `set -e` callers don't die when scope is
  # genuinely missing (e.g. unknown mode under a polluted ORCH_STATE_DIR).
  if [[ -z "$ISSUE_ARG" ]]; then
    current_pwd_abs || true
  fi
  return 0
}

scope_branch() {
  local wf b
  if wf=$(resolve_workflow_state_file 2>/dev/null) && [[ -f "$wf" ]]; then
    b=$(jq -r '.branch // empty' "$wf" 2>/dev/null || true)
    if [[ -n "$b" ]]; then
      printf '%s' "$b"
      return 0
    fi
  fi
  if [[ -z "$ISSUE_ARG" ]]; then
    git branch --show-current 2>/dev/null || true
  fi
  return 0
}

cmd_check() {
  detect_mode
  case "$MODE_RESULT" in
    managed|unknown) exit 0 ;;
    unmanaged)       exit 1 ;;
  esac
}

cmd_mode() {
  detect_mode
  printf '%s\n' "$MODE_RESULT"
}

cmd_scope_json() {
  detect_mode
  local issue worktree branch
  issue=$(scope_issue_id)
  worktree=$(scope_worktree)
  branch=$(scope_branch)
  jq -n \
    --arg mode "$MODE_RESULT" \
    --arg issue_id "${issue:-}" \
    --arg worktree "${worktree:-}" \
    --arg branch "${branch:-}" \
    '{mode:$mode, issue_id:$issue_id, worktree:$worktree, branch:$branch}'
}

cmd_current_issue()    { scope_issue_id; printf '\n'; }
cmd_current_worktree() { scope_worktree;  printf '\n'; }
cmd_current_branch()   { scope_branch;    printf '\n'; }

cmd_match_branch() {
  local target="${1:-}"
  [[ -z "$target" ]] && { echo "match-branch requires <branch>" >&2; exit 2; }
  local scoped
  scoped=$(scope_branch)
  [[ -n "$scoped" && "$target" == "$scoped" ]] && exit 0 || exit 1
}

cmd_match_worktree() {
  local target="${1:-}"
  [[ -z "$target" ]] && { echo "match-worktree requires <path>" >&2; exit 2; }
  local scoped abs_target abs_scoped
  scoped=$(scope_worktree)
  [[ -z "$scoped" ]] && exit 1
  abs_target=$(cd "$target" 2>/dev/null && pwd || printf '%s' "$target")
  abs_scoped=$(cd "$scoped" 2>/dev/null && pwd || printf '%s' "$scoped")
  [[ "$abs_target" == "$abs_scoped" ]] && exit 0 || exit 1
}

cmd_help() {
  cat <<'EOF'
Usage: flightdeck-mode [--issue <ID>] <command> [args]

Commands:
  check                       exit 0 if managed or unknown (fail-closed),
                              exit 1 only on explicit unmanaged
  mode                        print: managed | unmanaged | unknown
  scope-json                  print {mode, issue_id, worktree, branch}
  current-issue               print scoped issue id
  current-worktree            print scoped worktree absolute path
  current-branch              print scoped branch name
  match-branch <name>         exit 0 if <name> == scoped branch
  match-worktree <path>       exit 0 if <path> resolves to scoped worktree

Flags:
  --issue <ID>                force scope lookup to the named issue's
                              workflow-state file (safer when calling
                              from outside the worktree, e.g. main repo)

Environment:
  FLIGHTDECK_MANAGED=1        managed-mode signal set by Flightdeck spawns
  FLIGHTDECK_MANAGED=0        explicit standalone override
  FLIGHTDECK_CHILD_PANE=1     legacy alias (Pi child panes)
  FLIGHTDECK_STATE_DIR        master-state dir (default: tmp)
  ORCH_STATE_DIR              workflow-state dir (default: tmp)
  GH_ISSUE_PATTERN            regex for issue IDs (default: [A-Z]+-[0-9]+)
EOF
}

# Parse global flags up to the subcommand.
while [[ $# -gt 0 ]]; do
  case "$1" in
    --issue) ISSUE_ARG="$2"; shift 2 ;;
    --issue=*) ISSUE_ARG="${1#--issue=}"; shift ;;
    --) shift; break ;;
    -h|--help|help) cmd_help; exit 0 ;;
    *) break ;;
  esac
done

case "${1:-help}" in
  check)            shift; cmd_check "$@" ;;
  mode)             shift; cmd_mode "$@" ;;
  scope-json)       shift; cmd_scope_json "$@" ;;
  current-issue)    shift; cmd_current_issue "$@" ;;
  current-worktree) shift; cmd_current_worktree "$@" ;;
  current-branch)   shift; cmd_current_branch "$@" ;;
  match-branch)     shift; cmd_match_branch "$@" ;;
  match-worktree)   shift; cmd_match_worktree "$@" ;;
  help|--help|-h)   cmd_help ;;
  *) echo "Unknown command: $1" >&2; cmd_help >&2; exit 2 ;;
esac
