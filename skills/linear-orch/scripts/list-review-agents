#!/usr/bin/env bash
# Print the names of every `reviewer-*` agent installed in the active harness
# registries, one per line, deduped. Used by linear-orch/workflows/review-pr.md
# to enumerate the default review set without hardcoding a count.
#
# Sources scanned (in order): .pi/agents, .claude/agents, .agents (vstack-installed),
# .codex/agents, .opencode/agents. Missing dirs are skipped silently.
# Exit code is 0 if at least one reviewer was found, 1 if none.

set -u

dirs=(.pi/agents .claude/agents .agents .codex/agents .opencode/agents)
names=()

for dir in "${dirs[@]}"; do
    [ -d "$dir" ] || continue
    for f in "$dir"/reviewer-*; do
        [ -e "$f" ] || continue
        base=$(basename "$f")
        # Strip extension: .md, .toml, etc.
        name="${base%.*}"
        names+=("$name")
    done
done

if [ ${#names[@]} -eq 0 ]; then
    exit 1
fi

printf '%s\n' "${names[@]}" | sort -u
