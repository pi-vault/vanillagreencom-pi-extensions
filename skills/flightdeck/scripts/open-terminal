#!/usr/bin/env bash
# Launch worktree(s) for one or more issues with auto-detected harness and terminal.
#
# Usage:
#   open-terminal ISSUE-1 [--tmux | --ghostty] [--cmd "command {issue}"]
#   open-terminal ISSUE-1 ISSUE-2 ... [--tmux | --ghostty] [--cmd "command {issue}"]
#   open-terminal <group_id> [--tmux | --ghostty] [--cmd "command {issue}"]
#
# Options:
#   --cmd "..."    Command to run in each worktree. Use {issue} as placeholder
#                  for the issue ID. If omitted, auto-detects harness (claude/codex/opencode).
#   --tmux         Open tmux windows (requires active tmux session)
#   --ghostty      Open Ghostty terminals
#   (default)      Auto-detect: tmux if $TMUX set, else ghostty/GUI terminal
#
# Environment:
#   GH_ISSUE_PATTERN          - Regex pattern matching issue IDs (default: "[A-Z]+-[0-9]+")
#   OPEN_TERMINAL_NO_BYPASS=1 - Do not pass per-harness permission-bypass flags to spawned
#                               agents. Default off (bypass enabled). Inner agents need bypass
#                               to silently spawn sub-agent panes via tmux without prompting
#                               the (often absent) human at the master pane.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=lib/oc-paths.sh
source "$SCRIPT_DIR/lib/oc-paths.sh"

# Resolve project root (works in worktrees and main repos)
PROJECT_ROOT="$(git -C "$SCRIPT_DIR" rev-parse --show-toplevel 2>/dev/null)"
SKILLS_DIR="$PROJECT_ROOT/.agents/skills"
ENV_FILE="$PROJECT_ROOT/.env.local"
if [[ -f "$ENV_FILE" ]]; then
  # shellcheck source=/dev/null
  source "$ENV_FILE"
elif [[ -f "$PROJECT_ROOT/.env" ]]; then
  # shellcheck source=/dev/null
  source "$PROJECT_ROOT/.env"
fi

# Resolve WORKTREE_CLI from sibling skill
WORKTREE_CLI="${WORKTREE_CLI:-$SKILLS_DIR/worktree/scripts/worktree}"

# Configurable issue pattern (default: JIRA-style ABC-123)
GH_ISSUE_PATTERN="${GH_ISSUE_PATTERN:-[A-Z]+-[0-9]+}"

TERMINAL_MODE=""
HARNESS=""
ISSUES=()
GROUP_ID=""
CMD_TEMPLATE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --tmux) TERMINAL_MODE="tmux"; shift ;;
    --ghostty) TERMINAL_MODE="ghostty"; shift ;;
    --harness) HARNESS="$2"; shift 2 ;;
    --harness=*) HARNESS="${1#--harness=}"; shift ;;
    --cmd) CMD_TEMPLATE="$2"; shift 2 ;;
    --help|-h)
      echo "Usage: open-terminal ISSUE-1 [ISSUE-2 ...] [options]"
      echo ""
      echo "Options:"
      echo "  --harness <name>    Harness to launch: claude, codex, opencode, omp"
      echo "  --tmux              Open tmux windows (requires active tmux session)"
      echo "  --ghostty           Open Ghostty terminals"
      echo "  --cmd \"command\"     Custom command ({issue} is replaced). Overrides --harness."
      echo "  (default terminal)  Auto-detect: tmux if \$TMUX set, else GUI terminal"
      echo ""
      echo "Harness launch commands (with permission bypass enabled by default):"
      echo "  claude   → claude -n ISSUE --dangerously-skip-permissions --model 'opus[1m]' --effort max '/orchestration start ISSUE'"
      echo "  codex    → codex '\$orchestration start ISSUE'"
      echo "  opencode → opencode --prompt '/orchestration start ISSUE'"
      echo "  omp      → omp '/skill:orchestration start ISSUE'"
      echo ""
      echo "Environment:"
      echo "  GH_ISSUE_PATTERN          Regex for issue IDs (default: [A-Z]+-[0-9]+)"
      echo "  OPEN_TERMINAL_NO_BYPASS=1 Disable per-harness permission-bypass flags (default: off)"
      exit 0
      ;;
    [0-9]*) GROUP_ID="$1"; shift ;;
    *)
      # Match against configurable issue pattern
      if echo "$1" | grep -qiE "^${GH_ISSUE_PATTERN}$"; then
        ISSUES+=("$(echo "$1" | tr '[:lower:]' '[:upper:]')"); shift
      else
        echo "Error: unexpected argument: $1" >&2; exit 1
      fi
      ;;
  esac
done

# Auto-detect terminal mode
if [[ -z "$TERMINAL_MODE" ]]; then
  if [[ -n "${TMUX:-}" ]]; then
    TERMINAL_MODE="tmux"
  else
    TERMINAL_MODE="gui"
  fi
fi

# Resolve issues from group_id if no explicit issues
if [[ ${#ISSUES[@]} -eq 0 && -n "$GROUP_ID" ]]; then
  GROUPS_JSON=$("$SCRIPT_DIR/parallel-groups" read 2>/dev/null || echo "[]")
  GROUP_ISSUES=$(echo "$GROUPS_JSON" | jq -r --argjson gid "$GROUP_ID" '.[] | select(.group_id == $gid) | .issues[]' 2>/dev/null)
  if [[ -z "$GROUP_ISSUES" ]]; then
    echo "Error: no active group with id $GROUP_ID (may be stale)" >&2
    exit 1
  fi
  while IFS= read -r issue; do
    ISSUES+=("$issue")
  done <<< "$GROUP_ISSUES"
fi

# Require worktree CLI
if [[ ! -x "$WORKTREE_CLI" ]]; then
  echo "Error: WORKTREE_CLI not found at '$WORKTREE_CLI'. Is the worktree skill installed?" >&2
  exit 1
fi

if [[ ${#ISSUES[@]} -eq 0 ]]; then
  echo "Error: no issues specified" >&2
  exit 1
fi

if [[ -z "$HARNESS" && -z "$CMD_TEMPLATE" ]]; then
  echo "Error: --harness <claude|codex|opencode|omp> is required (or use --cmd)" >&2
  exit 1
fi

# --- Harness detection --------------------------------------------------------

# Permission-bypass flags per harness. Inner agents need bypass to silently
# run `tmux new-window` (or equivalent) when delegating to sub-agents. Without
# bypass the inner agent prompts on every spawn; master flightdeck has no
# human at its pane to approve, so the inner agent falls back to in-context
# spawning and sub-agents lose their own pane (and task-list isolation).
#
# Set OPEN_TERMINAL_NO_BYPASS=1 to disable. Codex/opencode bypass flags need
# per-harness verification before being added; left empty for now to avoid
# passing an unsupported flag to those harnesses. omp is yolo-by-default so
# no flag is needed.
bypass_flag_for_harness() {
  [[ -n "${OPEN_TERMINAL_NO_BYPASS:-}" ]] && return
  case "$1" in
    claude)   echo "--dangerously-skip-permissions" ;;
    codex|opencode|omp) echo "" ;;
  esac
}

detect_start_cmd() {
  local issue="$1"
  if [[ -n "$CMD_TEMPLATE" ]]; then
    echo "${CMD_TEMPLATE//\{issue\}/$issue}"
    return
  fi
  local bypass
  bypass="$(bypass_flag_for_harness "$HARNESS")"
  case "$HARNESS" in
    claude)   echo "claude -n \"$issue\" ${bypass} --model 'opus[1m]' --effort max '/orchestration start $issue'" ;;
    codex)    echo "codex '\$orchestration start $issue'" ;;
    opencode) echo "opencode --prompt '/orchestration start $issue'" ;;
    omp)      echo "omp '/skill:orchestration start $issue'" ;;
    *)        echo "" ;;
  esac
}

# --- Opencode HTTP-attach adapter (Phase 1) ----------------------------------
#
# Two-step launch (corrected from initial Phase 1 plan):
#   Step 0: spawn `opencode serve --port <PORT>` as a detached background
#           process (setsid + nohup). PID persisted in the spawn file.
#   Step 1: create a session via `opencode run --attach <URL> --agent build
#           --format json "<bootstrap>"`. Capturing the sessionID this way
#           makes opencode's session-creation logic auto-deny the question
#           and plan_enter/plan_exit tools (no answerable channel exists
#           for run --attach), forcing the agent to chat-text-only output.
#           This is intentional — modal UI prompts cannot be driven via
#           run --attach, so we eliminate that escape hatch at session
#           construction time.
#   Step 2: open the visible TUI in a tmux window via `opencode attach
#           <URL> --session <SID>`. The user sees a normal opencode TUI;
#           the data path is the same HTTP server.
#
# This replaces the original single-step `--port + --prompt` shape, which
# created sessions with `permission: null` (question tool ENABLED) — the
# orchestration agent would then render modal UI we couldn't drive.

resolve_opencode_bin() {
  if [[ -x /usr/bin/opencode ]]; then
    echo "/usr/bin/opencode"
    return 0
  fi
  local p
  p=$(type -P opencode 2>/dev/null || true)
  if [[ -n "$p" && -x "$p" ]]; then
    echo "$p"
    return 0
  fi
  return 1
}

# Spawn `opencode serve --port <PORT>` detached, with cwd=worktree so
# the server's session metadata reports the correct project root (NOT
# wherever open-terminal happened to be invoked from). Polls /session
# until the server answers, then resolves the *real* server PID via
# pgrep — the subshell `$!` is the launcher's bash, which exits as
# soon as setsid forks; the actual opencode serve process is a
# grandchild and reparented to init. Echoes the server PID on success.
start_oc_server() {
  local bin="$1" port="$2" wt_path="$3"
  local server_log; server_log=$(oc_server_log "$port")
  # Subshell: cd into the worktree before exec so the server inherits
  # the worktree as its cwd. setsid puts the server in its own pgroup
  # so cleanup can reap the whole tree via `kill -- -<pid>`.
  ( cd "$wt_path" && setsid nohup "$bin" serve --port "$port" --hostname 127.0.0.1 \
      </dev/null >>"$server_log" 2>&1 ) &
  local launcher_pid=$!
  local deadline=$((SECONDS + 15))
  local up=0
  while (( SECONDS < deadline )); do
    if curl -s --max-time 2 -o /dev/null -w '%{http_code}' "http://127.0.0.1:$port/session" 2>/dev/null \
        | grep -qE '^(200|404)$'; then
      up=1
      break
    fi
    sleep 0.5
  done
  if (( up == 0 )); then
    echo "  oc-attach-unavailable: opencode serve health timed out on port $port; check $server_log" >&2
    pkill -f "opencode serve --port $port" 2>/dev/null || true
    return 1
  fi
  # Resolve the real server PID by port match. Restrict to this user's
  # processes (-u) so we don't pick up another user's server if any.
  local server_pid
  server_pid=$(pgrep -u "$(id -u)" -f "opencode serve --port $port" | head -n 1)
  if [[ -z "$server_pid" ]]; then
    echo "  oc-attach-unavailable: server up on $port but pgrep found no matching process" >&2
    return 1
  fi
  echo "$server_pid"
}

# Step 1: create a session via run --attach with a minimal bootstrap
# prompt. The bootstrap MUST complete quickly (single short reply) —
# previously this was `/orchestration start $issue` which triggers the
# full workflow and blocks past the 60s timeout, hanging the spawn.
# Orchestration is fired as a backgrounded follow-up after the spawn
# completes (see fire_orchestration_async below). Run from the worktree
# so the session's cwd field reflects the worktree.
create_oc_session() {
  local bin="$1" url="$2" wt_path="$3"
  local bootstrap="reply with READY and nothing else"
  local out
  if ! out=$( cd "$wt_path" && timeout --kill-after=10 60 "$bin" run --attach "$url" \
               --agent build --format json "$bootstrap" 2>&1); then
    echo "  oc-attach-unavailable: opencode run --attach (session create) exit non-zero" >&2
    [[ -n "$out" ]] && printf '%s\n' "$out" | head -n 20 >&2
    return 1
  fi
  local sid
  sid=$(printf '%s\n' "$out" | jq -r 'select(.sessionID // .session_id // .sessionId) | (.sessionID // .session_id // .sessionId)' 2>/dev/null | head -n 1)
  if [[ -z "$sid" || "$sid" == "null" ]]; then
    echo "  oc-attach-unavailable: could not parse sessionID from create output" >&2
    printf '%s\n' "$out" | head -n 20 >&2
    return 1
  fi
  echo "$sid"
}

# Fire `/orchestration start <issue>` as a backgrounded follow-up. This
# is what actually starts the per-issue agent's work; it can run for
# minutes and is fire-and-forget from open-terminal's perspective. The
# user-visible `opencode attach` TUI in step 2 will display the turn
# as it streams. setsid + log redirection so this survives open-terminal
# exit and doesn't pollute the launcher's stdio.
fire_orchestration_async() {
  local bin="$1" url="$2" sid="$3" issue="$4" wt_path="$5"
  local log; log=$(oc_server_log "${url##*:}")
  ( cd "$wt_path" && setsid nohup "$bin" run --attach "$url" \
      --session "$sid" --format json "/orchestration start $issue" \
      </dev/null >>"$log".orch 2>&1 ) &
  disown 2>/dev/null || true
}

# Tmux-mode opencode spawn (two-step). Returns 0 on success with bridge
# metadata persisted in oc_spawn_file($issue). Any failure path cleans up
# its own resources (server kill, port release) and returns non-zero —
# caller falls through to legacy spawn.
spawn_oc_attach_tmux() {
  local issue="$1" wt_path="$2"
  local bin port server_pid sid

  if ! bin=$(resolve_opencode_bin); then
    echo "  oc-attach-unavailable: opencode binary not found (PATH or /usr/bin)" >&2
    return 1
  fi
  if ! port=$(oc_alloc_port "$issue"); then
    echo "  oc-attach-unavailable: no free port in $OC_PORT_RANGE_START-$OC_PORT_RANGE_END" >&2
    return 1
  fi

  if ! server_pid=$(start_oc_server "$bin" "$port" "$wt_path"); then
    oc_release_port "$port"
    return 1
  fi

  # Update the ports allocator entry with the actual server PID. Without
  # this, oc_alloc_port's sweep records the launcher's $$, which dies as
  # soon as open-terminal exits — next sweep then drops the entry while
  # the opencode serve process is still alive on that port.
  oc_register_port_pid "$port" "$server_pid"

  if ! sid=$(create_oc_session "$bin" "http://127.0.0.1:$port" "$wt_path"); then
    kill -- -"$server_pid" 2>/dev/null || kill "$server_pid" 2>/dev/null || true
    oc_release_port "$port"
    return 1
  fi

  local attach_cmd
  attach_cmd=$(printf "%s attach http://127.0.0.1:%s --session %s" "$bin" "$port" "$sid")
  if ! open_tmux "$wt_path" "$issue" "$attach_cmd"; then
    kill -- -"$server_pid" 2>/dev/null || kill "$server_pid" 2>/dev/null || true
    oc_release_port "$port"
    return 1
  fi

  local spawn_file abs_wt
  spawn_file=$(oc_spawn_file "$issue")
  abs_wt=$(cd "$wt_path" && pwd)
  jq -nc \
    --arg url "http://127.0.0.1:$port" \
    --arg sid "$sid" \
    --arg dir "$abs_wt" \
    --argjson port "$port" \
    --argjson server_pid "$server_pid" \
    --arg ts "$(date -Iseconds)" \
    '{url:$url, session_id:$sid, directory:$dir, port:$port, server_pid:$server_pid, allocated_at:$ts}' \
    > "$spawn_file"

  # Fire the actual orchestration workflow as a backgrounded follow-up.
  # The bootstrap above only created the session (with a "READY" reply);
  # this is what kicks off /orchestration start <issue>. Logs to
  # oc-serve-<port>.log.orch so the master can tail if needed.
  fire_orchestration_async "$bin" "http://127.0.0.1:$port" "$sid" "$issue" "$wt_path"

  echo "  oc-attach: port=$port session=$sid server_pid=$server_pid"
  return 0
}

# --- Terminal launchers -------------------------------------------------------

# Pre-trust directory in Claude Code config so the trust dialog is skipped
pretrust_claude_dir() {
  local dir="$1"
  local claude_json="${CLAUDE_CONFIG_DIR:+$CLAUDE_CONFIG_DIR/claude.json}"
  claude_json="${claude_json:-$HOME/.claude.json}"
  if [[ -f "$claude_json" ]]; then
    local abs_dir
    abs_dir="$(cd "$dir" && pwd)"
    if ! jq -e --arg p "$abs_dir" '.projects[$p].hasTrustDialogAccepted' "$claude_json" >/dev/null 2>&1; then
      local tmp_json
      tmp_json=$(mktemp)
      jq --arg p "$abs_dir" '.projects[$p] = (.projects[$p] // {}) + {hasTrustDialogAccepted: true}' "$claude_json" > "$tmp_json" && mv "$tmp_json" "$claude_json"
    fi
  fi
}

open_tmux() {
  local dir="$1" name="$2" cmd="$3"
  if [[ -z "${TMUX:-}" ]]; then
    echo "Error: not inside a tmux session" >&2
    return 1
  fi
  local last_idx
  last_idx=$(tmux list-windows -F '#{window_index}' | tail -1)
  tmux new-window -a -t ":${last_idx}" -n "$name" -c "$dir"
  tmux send-keys "clear" Enter
  if [[ -n "$cmd" ]]; then
    tmux send-keys -l "$cmd"
    tmux send-keys Enter
  fi
  echo "  Opened tmux window '$name' in $dir"
}

open_gui() {
  local dir="$1" title="$2" cmd="$3"
  local shell_cmd
  if [[ -n "$cmd" ]]; then
    shell_cmd="cd '$dir' && $cmd"
  else
    shell_cmd="cd '$dir'; exec \$SHELL"
  fi

  if [[ "$OSTYPE" == "darwin"* ]]; then
    if [[ -d "/Applications/Ghostty.app" ]]; then
      local args=(--working-directory="$dir")
      [[ -n "$title" ]] && args+=(--title="$title")
      if [[ -n "$cmd" ]]; then
        open -na "Ghostty.app" --args "${args[@]}" --command="$cmd"
      else
        open -na "Ghostty.app" --args "${args[@]}"
      fi
    elif command -v open &>/dev/null; then
      if [[ -n "$cmd" ]]; then
        osascript -e "tell application \"Terminal\" to do script \"cd '$dir' && $cmd\""
      else
        open -a Terminal "$dir"
      fi
    else
      echo "Error: no supported terminal emulator found on macOS" >&2
      return 1
    fi
  elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
    if command -v ghostty &>/dev/null; then
      local args=(--working-directory="$dir")
      [[ -n "$title" ]] && args+=(--title="$title")
      if [[ -n "$cmd" ]]; then
        setsid env -u CLAUDECODE ghostty "${args[@]}" -e bash -c "$shell_cmd" </dev/null &>/dev/null &
      else
        setsid env -u CLAUDECODE ghostty "${args[@]}" </dev/null &>/dev/null &
      fi
    elif command -v xdg-terminal-exec &>/dev/null; then
      setsid env -u CLAUDECODE xdg-terminal-exec bash -c "$shell_cmd" </dev/null &>/dev/null &
    elif command -v xterm &>/dev/null; then
      local xargs=()
      [[ -n "$title" ]] && xargs+=(-T "$title")
      setsid env -u CLAUDECODE xterm "${xargs[@]}" -e bash -c "$shell_cmd" </dev/null &>/dev/null &
    else
      echo "Error: no supported terminal emulator found" >&2
      return 1
    fi
  else
    echo "Error: unsupported platform: $OSTYPE" >&2
    return 1
  fi
  echo "  Opened terminal for $title in $dir"
}

# --- Main loop ----------------------------------------------------------------

if [[ ${#ISSUES[@]} -eq 1 ]]; then
  echo "Launching worktree (${TERMINAL_MODE})..."
else
  echo "Launching ${#ISSUES[@]} worktrees (${TERMINAL_MODE})..."
fi

LAUNCHED=0
FAILED=()

for ISSUE in "${ISSUES[@]}"; do
  # Create worktree (reuses existing) — capture stderr separately
  _wt_err=$(mktemp)
  if ! WT_PATH=$("$WORKTREE_CLI" create "$ISSUE" 2>"$_wt_err"); then
    echo "  Failed to create worktree: $(cat "$_wt_err")" >&2
    rm -f "$_wt_err"
    FAILED+=("$ISSUE")
    continue
  fi
  rm -f "$_wt_err"

  # Only pretrust for Claude harness
  if command -v claude &>/dev/null; then
    pretrust_claude_dir "$WT_PATH"
  fi

  # Opencode HTTP-attach (tmux mode only): allocate a port, spawn with
  # --port + bootstrap prompt, discover the session id, persist for
  # pane-registry. Falls back to legacy spawn on any adapter failure so
  # the pane still launches — pane-respond / pane-poll detect the absent
  # spawn file and use the tmux send-keys / capture-pane fallback path.
  if [[ "$TERMINAL_MODE" == "tmux" && "$HARNESS" == "opencode" && -z "$CMD_TEMPLATE" ]]; then
    if spawn_oc_attach_tmux "$ISSUE" "$WT_PATH"; then
      LAUNCHED=$((LAUNCHED + 1))
      continue
    fi
    # fall through to legacy spawn below
  fi

  START_CMD=$(detect_start_cmd "$ISSUE")

  if [[ "$TERMINAL_MODE" == "tmux" ]]; then
    open_tmux "$WT_PATH" "$ISSUE" "$START_CMD"
  else
    open_gui "$WT_PATH" "$ISSUE" "$START_CMD"
  fi
  LAUNCHED=$((LAUNCHED + 1))
done

if [[ ${#FAILED[@]} -gt 0 ]]; then
  echo "Launched $LAUNCHED, failed ${#FAILED[@]}: ${FAILED[*]}" >&2
  exit 1
fi

echo "Done — $LAUNCHED worktree(s) launched."
