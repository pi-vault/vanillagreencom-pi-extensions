#!/usr/bin/env bash
# Launch worktree(s) for one or more issues with auto-detected harness and terminal.
#
# Usage:
#   open-terminal ISSUE-1 [--tmux | --ghostty] [--cmd "command {issue}"]
#   open-terminal ISSUE-1 ISSUE-2 ... [--tmux | --ghostty] [--cmd "command {issue}"]
#   open-terminal <group_id> [--tmux | --ghostty] [--cmd "command {issue}"]
#
# Options:
#   --cmd "..."    Command to run in each worktree. Use {issue} as placeholder
#                  for the issue ID. If omitted, auto-detects harness (claude/codex/opencode).
#   --tmux         Open tmux windows (requires active tmux session)
#   --ghostty      Open Ghostty terminals
#   (default)      Auto-detect: tmux if $TMUX set, else ghostty/GUI terminal
#
# Environment:
#   GH_ISSUE_PATTERN          - Regex pattern matching issue IDs (default: "[A-Z]+-[0-9]+")
#   OPEN_TERMINAL_NO_BYPASS=1 - Do not pass per-harness permission-bypass flags to spawned
#                               agents. Default off (bypass enabled). Inner agents need bypass
#                               to silently spawn sub-agent panes via tmux without prompting
#                               the (often absent) human at the master pane.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=lib/oc-paths.sh
source "$SCRIPT_DIR/lib/oc-paths.sh"
# shellcheck source=lib/cc-channel-paths.sh
source "$SCRIPT_DIR/lib/cc-channel-paths.sh"
# shellcheck source=lib/pi-bridge-paths.sh
source "$SCRIPT_DIR/lib/pi-bridge-paths.sh"
# shellcheck source=lib/codex-paths.sh
source "$SCRIPT_DIR/lib/codex-paths.sh"

# Resolve project root (works in worktrees and main repos)
PROJECT_ROOT="$(git -C "$SCRIPT_DIR" rev-parse --show-toplevel 2>/dev/null)"
SKILLS_DIR="$PROJECT_ROOT/.agents/skills"
ENV_FILE="$PROJECT_ROOT/.env.local"
if [[ -f "$ENV_FILE" ]]; then
  # shellcheck source=/dev/null
  source "$ENV_FILE"
elif [[ -f "$PROJECT_ROOT/.env" ]]; then
  # shellcheck source=/dev/null
  source "$PROJECT_ROOT/.env"
fi

# Resolve WORKTREE_CLI from sibling skill
WORKTREE_CLI="${WORKTREE_CLI:-$SKILLS_DIR/worktree/scripts/worktree}"

# Configurable issue pattern (default: JIRA-style ABC-123)
GH_ISSUE_PATTERN="${GH_ISSUE_PATTERN:-[A-Z]+-[0-9]+}"

TERMINAL_MODE=""
HARNESS=""
ISSUES=()
USE_CHANNELS="${FLIGHTDECK_CLAUDE_CHANNELS:-0}"
GROUP_ID=""
CMD_TEMPLATE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --tmux) TERMINAL_MODE="tmux"; shift ;;
    --ghostty) TERMINAL_MODE="ghostty"; shift ;;
    --harness) HARNESS="$2"; shift 2 ;;
    --harness=*) HARNESS="${1#--harness=}"; shift ;;
    --cmd) CMD_TEMPLATE="$2"; shift 2 ;;
    --use-channels) USE_CHANNELS=1; shift ;;
    --no-channels)  USE_CHANNELS=0; shift ;;
    --help|-h)
      echo "Usage: open-terminal ISSUE-1 [ISSUE-2 ...] [options]"
      echo ""
      echo "Options:"
      echo "  --harness <name>    Harness to launch: claude, codex, opencode, omp"
      echo "  --tmux              Open tmux windows (requires active tmux session)"
      echo "  --ghostty           Open Ghostty terminals"
      echo "  --cmd \"command\"     Custom command ({issue} is replaced). Overrides --harness."
      echo "  (default terminal)  Auto-detect: tmux if \$TMUX set, else GUI terminal"
      echo ""
      echo "Harness launch commands (with permission bypass enabled by default):"
      echo "  claude   → claude -n ISSUE --dangerously-skip-permissions --model 'opus[1m]' --effort max '/orchestration start ISSUE'"
      echo "  codex    → codex '\$orchestration start ISSUE'"
      echo "  opencode → opencode --prompt '/orchestration start ISSUE'"
      echo "  omp      → omp '/skill:orchestration start ISSUE'"
      echo ""
      echo "Environment:"
      echo "  GH_ISSUE_PATTERN          Regex for issue IDs (default: [A-Z]+-[0-9]+)"
      echo "  OPEN_TERMINAL_NO_BYPASS=1 Disable per-harness permission-bypass flags (default: off)"
      exit 0
      ;;
    [0-9]*) GROUP_ID="$1"; shift ;;
    *)
      # Match against configurable issue pattern
      if echo "$1" | grep -qiE "^${GH_ISSUE_PATTERN}$"; then
        ISSUES+=("$(echo "$1" | tr '[:lower:]' '[:upper:]')"); shift
      else
        echo "Error: unexpected argument: $1" >&2; exit 1
      fi
      ;;
  esac
done

# Auto-detect terminal mode
if [[ -z "$TERMINAL_MODE" ]]; then
  if [[ -n "${TMUX:-}" ]]; then
    TERMINAL_MODE="tmux"
  else
    TERMINAL_MODE="gui"
  fi
fi

# Resolve issues from group_id if no explicit issues
if [[ ${#ISSUES[@]} -eq 0 && -n "$GROUP_ID" ]]; then
  GROUPS_JSON=$("$SCRIPT_DIR/parallel-groups" read 2>/dev/null || echo "[]")
  GROUP_ISSUES=$(echo "$GROUPS_JSON" | jq -r --argjson gid "$GROUP_ID" '.[] | select(.group_id == $gid) | .issues[]' 2>/dev/null)
  if [[ -z "$GROUP_ISSUES" ]]; then
    echo "Error: no active group with id $GROUP_ID (may be stale)" >&2
    exit 1
  fi
  while IFS= read -r issue; do
    ISSUES+=("$issue")
  done <<< "$GROUP_ISSUES"
fi

# Require worktree CLI
if [[ ! -x "$WORKTREE_CLI" ]]; then
  echo "Error: WORKTREE_CLI not found at '$WORKTREE_CLI'. Is the worktree skill installed?" >&2
  exit 1
fi

if [[ ${#ISSUES[@]} -eq 0 ]]; then
  echo "Error: no issues specified" >&2
  exit 1
fi

if [[ -z "$HARNESS" && -z "$CMD_TEMPLATE" ]]; then
  echo "Error: --harness <claude|codex|opencode|omp> is required (or use --cmd)" >&2
  exit 1
fi

# --- Harness detection --------------------------------------------------------

# Permission-bypass flags per harness. Inner agents need bypass to silently
# run `tmux new-window` (or equivalent) when delegating to sub-agents. Without
# bypass the inner agent prompts on every spawn; master flightdeck has no
# human at its pane to approve, so the inner agent falls back to in-context
# spawning and sub-agents lose their own pane (and task-list isolation).
#
# Set OPEN_TERMINAL_NO_BYPASS=1 to disable. Codex/opencode bypass flags need
# per-harness verification before being added; left empty for now to avoid
# passing an unsupported flag to those harnesses. omp is yolo-by-default so
# no flag is needed.
bypass_flag_for_harness() {
  [[ -n "${OPEN_TERMINAL_NO_BYPASS:-}" ]] && return
  case "$1" in
    claude)   echo "--dangerously-skip-permissions" ;;
    codex|opencode|omp) echo "" ;;
  esac
}

detect_start_cmd() {
  local issue="$1"
  if [[ -n "$CMD_TEMPLATE" ]]; then
    echo "${CMD_TEMPLATE//\{issue\}/$issue}"
    return
  fi
  local bypass
  bypass="$(bypass_flag_for_harness "$HARNESS")"
  case "$HARNESS" in
    claude)   echo "claude -n \"$issue\" ${bypass} --model 'opus[1m]' --effort max '/orchestration start $issue'" ;;
    codex)    echo "codex '\$orchestration start $issue'" ;;
    opencode) echo "opencode --prompt '/orchestration start $issue'" ;;
    omp)      echo "omp '/skill:orchestration start $issue'" ;;
    pi)       echo "pi '/orchestration start $issue'" ;;
    *)        echo "" ;;
  esac
}

# --- Opencode HTTP-attach adapter (Phase 1) ----------------------------------
#
# Two-step launch (corrected from initial Phase 1 plan):
#   Step 0: spawn `opencode serve --port <PORT>` as a detached background
#           process (setsid + nohup). PID persisted in the spawn file.
#   Step 1: create a session via `opencode run --attach <URL> --agent build
#           --format json "<bootstrap>"`. Capturing the sessionID this way
#           makes opencode's session-creation logic auto-deny the question
#           and plan_enter/plan_exit tools (no answerable channel exists
#           for run --attach), forcing the agent to chat-text-only output.
#           This is intentional — modal UI prompts cannot be driven via
#           run --attach, so we eliminate that escape hatch at session
#           construction time.
#   Step 2: open the visible TUI in a tmux window via `opencode attach
#           <URL> --session <SID>`. The user sees a normal opencode TUI;
#           the data path is the same HTTP server.
#
# This replaces the original single-step `--port + --prompt` shape, which
# created sessions with `permission: null` (question tool ENABLED) — the
# orchestration agent would then render modal UI we couldn't drive.

resolve_opencode_bin() {
  if [[ -x /usr/bin/opencode ]]; then
    echo "/usr/bin/opencode"
    return 0
  fi
  local p
  p=$(type -P opencode 2>/dev/null || true)
  if [[ -n "$p" && -x "$p" ]]; then
    echo "$p"
    return 0
  fi
  return 1
}

# Spawn `opencode serve --port <PORT>` detached, with cwd=worktree so
# the server's session metadata reports the correct project root (NOT
# wherever open-terminal happened to be invoked from). Polls /session
# until the server answers, then resolves the *real* server PID via
# pgrep — the subshell `$!` is the launcher's bash, which exits as
# soon as setsid forks; the actual opencode serve process is a
# grandchild and reparented to init. Echoes the server PID on success.
start_oc_server() {
  local bin="$1" port="$2" wt_path="$3"
  local server_log; server_log=$(oc_server_log "$port")
  # Subshell: cd into the worktree before exec so the server inherits
  # the worktree as its cwd. setsid puts the server in its own pgroup
  # so cleanup can reap the whole tree via `kill -- -<pid>`.
  #
  # CRITICAL FD detachment: the OUTER `</dev/null >/dev/null 2>&1` on
  # the subshell prevents the subshell (and any descendant that
  # inherits its FDs before redirection takes effect) from holding open
  # the function's stdout, which is the captured `$(...)` pipe. Without
  # the outer redirect, the server's grandchildren keep the pipe alive
  # and `server_pid=$(start_oc_server ...)` hangs forever.
  ( cd "$wt_path" && setsid nohup "$bin" serve --port "$port" --hostname 127.0.0.1 \
      </dev/null >>"$server_log" 2>&1 ) </dev/null >/dev/null 2>&1 &
  local launcher_pid=$!
  local deadline=$((SECONDS + 15))
  local up=0
  while (( SECONDS < deadline )); do
    if curl -s --max-time 2 -o /dev/null -w '%{http_code}' "http://127.0.0.1:$port/session" 2>/dev/null \
        | grep -qE '^(200|404)$'; then
      up=1
      break
    fi
    sleep 0.5
  done
  if (( up == 0 )); then
    echo "  oc-attach-unavailable: opencode serve health timed out on port $port; check $server_log" >&2
    pkill -f "opencode serve --port $port" 2>/dev/null || true
    return 1
  fi
  # Resolve the real server PID by port match. Restrict to this user's
  # processes (-u) so we don't pick up another user's server if any.
  local server_pid
  server_pid=$(pgrep -u "$(id -u)" -f "opencode serve --port $port" | head -n 1)
  if [[ -z "$server_pid" ]]; then
    echo "  oc-attach-unavailable: server up on $port but pgrep found no matching process" >&2
    return 1
  fi
  echo "$server_pid"
}

# Step 1: create a session via run --attach with a minimal bootstrap
# prompt. The bootstrap MUST complete quickly (single short reply) —
# previously this was `/orchestration start $issue` which triggers the
# full workflow and blocks past the 60s timeout, hanging the spawn.
# Orchestration is fired as a backgrounded follow-up after the spawn
# completes (see fire_orchestration_async below). Run from the worktree
# so the session's cwd field reflects the worktree.
create_oc_session() {
  local bin="$1" url="$2" wt_path="$3"
  local bootstrap="reply with READY and nothing else"
  local out
  if ! out=$( cd "$wt_path" && timeout --kill-after=10 60 "$bin" run --attach "$url" \
               --agent build --format json "$bootstrap" 2>&1); then
    echo "  oc-attach-unavailable: opencode run --attach (session create) exit non-zero" >&2
    [[ -n "$out" ]] && printf '%s\n' "$out" | head -n 20 >&2
    return 1
  fi
  local sid
  sid=$(printf '%s\n' "$out" | jq -r 'select(.sessionID // .session_id // .sessionId) | (.sessionID // .session_id // .sessionId)' 2>/dev/null | head -n 1)
  if [[ -z "$sid" || "$sid" == "null" ]]; then
    echo "  oc-attach-unavailable: could not parse sessionID from create output" >&2
    printf '%s\n' "$out" | head -n 20 >&2
    return 1
  fi
  echo "$sid"
}

# Fire `/orchestration start <issue>` as a backgrounded follow-up. This
# is what actually starts the per-issue agent's work; it can run for
# minutes and is fire-and-forget from open-terminal's perspective. The
# user-visible `opencode attach` TUI in step 2 will display the turn
# as it streams. setsid + log redirection so this survives open-terminal
# exit and doesn't pollute the launcher's stdio.
#
# Env overrides (intended for tests / alt workflows):
#   FLIGHTDECK_OC_FOLLOWUP_PROMPT — replace the default `/orchestration
#       start <ISSUE>` prompt entirely. Use literal `__ISSUE__` in the
#       value to substitute the issue id at fire time (multi-issue
#       spawns share one env, but each issue gets its own substitution).
#   FLIGHTDECK_OC_SKIP_FOLLOWUP=1 — skip the followup fire entirely;
#       useful when callers will drive the session via run --attach
#       themselves and want the spawn to bring up only the bridge.
fire_orchestration_async() {
  local bin="$1" url="$2" sid="$3" issue="$4" wt_path="$5"
  if [[ "${FLIGHTDECK_OC_SKIP_FOLLOWUP:-0}" == "1" ]]; then
    return 0
  fi
  local log; log=$(oc_server_log "${url##*:}")
  local prompt
  if [[ -n "${FLIGHTDECK_OC_FOLLOWUP_PROMPT:-}" ]]; then
    prompt="${FLIGHTDECK_OC_FOLLOWUP_PROMPT//__ISSUE__/$issue}"
  else
    prompt="/orchestration start $issue"
  fi
  # Outer redirect detaches the subshell's FDs from anything the caller
  # might be capturing — same hazard as start_oc_server.
  ( cd "$wt_path" && setsid nohup "$bin" run --attach "$url" \
      --session "$sid" --format json "$prompt" \
      </dev/null >>"$log".orch 2>&1 ) </dev/null >/dev/null 2>&1 &
  disown 2>/dev/null || true
}

# Tmux-mode opencode spawn (two-step). Returns 0 on success with bridge
# metadata persisted in oc_spawn_file($issue). Any failure path cleans up
# its own resources (server kill, port release) and returns non-zero —
# caller falls through to legacy spawn.
spawn_oc_attach_tmux() {
  local issue="$1" wt_path="$2"
  local bin port server_pid sid pane_id

  if ! bin=$(resolve_opencode_bin); then
    echo "  oc-attach-unavailable: opencode binary not found (PATH or /usr/bin)" >&2
    return 1
  fi
  if ! port=$(oc_alloc_port "$issue"); then
    echo "  oc-attach-unavailable: no free port in $OC_PORT_RANGE_START-$OC_PORT_RANGE_END" >&2
    return 1
  fi

  # Pre-create the tmux window WITH a captured pane id BEFORE starting
  # the opencode server. Reason: the opentmux plugin (~/.config/opencode/
  # plugins/opentmux) reads `process.env.TMUX_PANE` at server init to
  # decide which pane to split sub-agents off of. setsid+nohup on the
  # server otherwise inherits TMUX_PANE from the launcher's shell — which
  # is the master pane (e.g., HT:pi.1) — so every sub-agent split lands
  # in the master window instead of the per-issue window. By creating
  # the inner pane first and exporting TMUX_PANE=<that pane id> for
  # `start_oc_server`, the plugin captures the correct pane and splits
  # sub-agents into the issue's own window.
  if [[ -z "${TMUX:-}" ]]; then
    echo "  oc-attach-unavailable: not inside a tmux session" >&2
    oc_release_port "$port"
    return 1
  fi
  local last_idx
  last_idx=$(tmux list-windows -F '#{window_index}' | tail -1)
  pane_id=$(tmux new-window -a -t ":${last_idx}" -n "$issue" -c "$wt_path" -d -P -F '#{pane_id}' 2>/dev/null)
  if [[ -z "$pane_id" ]]; then
    echo "  oc-attach-unavailable: failed to create tmux window for $issue" >&2
    oc_release_port "$port"
    return 1
  fi

  # Start the server with TMUX_PANE pointing at the just-created inner
  # pane. The function-level prefix flows through the inner subshell's
  # setsid+nohup fork.
  if ! server_pid=$(TMUX_PANE="$pane_id" start_oc_server "$bin" "$port" "$wt_path"); then
    tmux kill-pane -t "$pane_id" 2>/dev/null || true
    oc_release_port "$port"
    return 1
  fi

  # Update the ports allocator entry with the actual server PID. Without
  # this, oc_alloc_port's sweep records the launcher's $$, which dies as
  # soon as open-terminal exits — next sweep then drops the entry while
  # the opencode serve process is still alive on that port.
  oc_register_port_pid "$port" "$server_pid"

  if ! sid=$(create_oc_session "$bin" "http://127.0.0.1:$port" "$wt_path"); then
    kill -- -"$server_pid" 2>/dev/null || kill "$server_pid" 2>/dev/null || true
    tmux kill-pane -t "$pane_id" 2>/dev/null || true
    oc_release_port "$port"
    return 1
  fi

  # Send the actual `opencode attach` command into the pre-created pane.
  # Using send-keys preserves the existing UX (clear → type cmd → Enter)
  # so the pane shows the command in its scrollback.
  local attach_cmd
  attach_cmd=$(printf "%s attach http://127.0.0.1:%s --session %s" "$bin" "$port" "$sid")
  tmux send-keys -t "$pane_id" "clear" Enter
  tmux send-keys -t "$pane_id" -l "$attach_cmd"
  tmux send-keys -t "$pane_id" Enter
  echo "  Opened tmux window '$issue' in $wt_path (pane $pane_id)"

  local spawn_file abs_wt
  spawn_file=$(oc_spawn_file "$issue")
  abs_wt=$(cd "$wt_path" && pwd)
  jq -nc \
    --arg url "http://127.0.0.1:$port" \
    --arg sid "$sid" \
    --arg dir "$abs_wt" \
    --argjson port "$port" \
    --argjson server_pid "$server_pid" \
    --arg ts "$(date -Iseconds)" \
    '{url:$url, session_id:$sid, directory:$dir, port:$port, server_pid:$server_pid, allocated_at:$ts}' \
    > "$spawn_file"

  # Fire the actual orchestration workflow as a backgrounded follow-up.
  # The bootstrap above only created the session (with a "READY" reply);
  # this is what kicks off /orchestration start <issue>. Logs to
  # oc-serve-<port>.log.orch so the master can tail if needed.
  fire_orchestration_async "$bin" "http://127.0.0.1:$port" "$sid" "$issue" "$wt_path"

  echo "  oc-attach: port=$port session=$sid server_pid=$server_pid"
  return 0
}

# --- Claude code Channels adapter (Phase 2) -----------------------------------
#
# Opt-in via FLIGHTDECK_CLAUDE_CHANNELS=1 or --use-channels. Default
# claude spawn stays on the existing tmux send-keys / capture-pane path.
#
# Spawn flow:
#   1. Verify deps (claude >=2.1.80, claude.ai auth, bun).
#   2. Idempotent bootstrap of the vendored MCP webhook (bun install).
#   3. Allocate channel port from 8780-8879 (host-global, flock).
#   4. Pin a deterministic session UUID derived from the issue id.
#   5. Write per-pane .mcp.json under FD_STATE_DIR/cc-channel/<ISSUE>/.
#   6. Spawn claude in tmux with --session-id, --mcp-config, and
#      --dangerously-load-development-channels server:webhook.
#   7. Persist {url, port, session_uuid, transcript, directory, mcp_path}
#      to cc_spawn_file($issue) for pane-registry / pane-respond /
#      pane-poll / daemon to discover.
#
# Outbound (in pane-poll / daemon): tail
#   ~/.claude/projects/<encoded-cwd>/<uuid>.jsonl
# Inbound (in pane-respond): POST to http://127.0.0.1:<port>/.

resolve_claude_bin() {
  if [[ -x /usr/bin/claude ]]; then
    echo "/usr/bin/claude"
    return 0
  fi
  local p
  p=$(type -P claude 2>/dev/null || true)
  if [[ -n "$p" && -x "$p" ]]; then
    echo "$p"
    return 0
  fi
  return 1
}

# Verify claude version is >= 2.1.80 (channels minimum).
cc_verify_claude_version() {
  local bin="$1"
  local ver_line; ver_line=$("$bin" --version 2>/dev/null | head -n 1)
  # Format example: "2.1.119 (Claude Code)"
  local v; v=$(echo "$ver_line" | awk '{print $1}')
  [[ -z "$v" ]] && return 1
  local major minor patch
  IFS='.' read -r major minor patch <<< "$v"
  if [[ "$major" -gt 2 ]]; then return 0; fi
  if [[ "$major" -eq 2 && "$minor" -gt 1 ]]; then return 0; fi
  if [[ "$major" -eq 2 && "$minor" -eq 1 && "$patch" -ge 80 ]]; then return 0; fi
  return 1
}

# Verify claude.ai auth is in use (Channels won't work with API key /
# Bedrock / Vertex). claude auth status output varies; we just look for
# any indication of claude.ai login.
cc_verify_claude_auth() {
  local bin="$1"
  local out; out=$("$bin" auth status 2>&1 | head -n 20)
  grep -qiE 'claude\.ai|authMethod.*claude\.ai|Login Method.*Claude (Account|Pro|Max)' <<< "$out"
}

cc_write_mcp_config() {
  local issue="$1" port="$2"
  local mcp_dir; mcp_dir=$(cc_mcp_dir "$issue")
  mkdir -p "$mcp_dir"
  local webhook="$SCRIPT_DIR/../lib/claude-channel-server/webhook.ts"
  webhook=$(cd "$(dirname "$webhook")" && pwd)/$(basename "$webhook")
  jq -n \
    --arg cmd "bun" \
    --arg path "$webhook" \
    --arg port "$port" \
    --arg session "$issue" \
    '{
      mcpServers: {
        webhook: {
          command: $cmd,
          args: [$path],
          env: { CC_CHANNEL_PORT: $port, CC_CHANNEL_SESSION: $session }
        }
      }
    }' > "$(cc_mcp_config "$issue")"
  cc_mcp_config "$issue"
}

# Build claude spawn cmd for tmux. The `--` separator BEFORE the
# prompt is critical: --dangerously-load-development-channels accepts
# multiple values (variadic), so without `--` claude consumes the
# prompt as a second channel entry and errors with
# "entries must be tagged: <prompt>".
#
# The trust prompt for --dangerously-load-development-channels is
# dismissed via a delayed tmux send-keys after the pane opens.
build_claude_channel_cmd() {
  local bin="$1" mcp_path="$2" uuid="$3" issue="$4" bypass="$5"
  printf "%s -n %q %s --model 'opus[1m]' --effort max --session-id %s --mcp-config %q --dangerously-load-development-channels server:webhook -- '/orchestration start %s'" \
    "$bin" "$issue" "$bypass" "$uuid" "$mcp_path" "$issue"
}

# Tmux-mode claude channels spawn. Returns 0 on success with bridge
# metadata persisted in cc_spawn_file($issue). Any failure path cleans
# up its own resources (port release, mcp dir keep) and returns
# non-zero — caller falls through to legacy spawn.
spawn_cc_channel_tmux() {
  local issue="$1" wt_path="$2"
  local bin port uuid mcp_path

  if ! bin=$(resolve_claude_bin); then
    echo "  cc-channel-unavailable: claude binary not found (PATH or /usr/bin)" >&2
    return 1
  fi
  if ! cc_verify_claude_version "$bin"; then
    echo "  cc-channel-unavailable: claude version is < 2.1.80 (channels minimum)" >&2
    return 1
  fi
  if ! cc_verify_claude_auth "$bin"; then
    echo "  cc-channel-unavailable: claude.ai auth required (channels don't work with API key / Bedrock / Vertex)" >&2
    return 1
  fi
  if ! "$SCRIPT_DIR/../lib/claude-channel-server/bootstrap" >&2; then
    echo "  cc-channel-unavailable: claude-channel-server bootstrap failed" >&2
    return 1
  fi

  if ! port=$(cc_alloc_port "$issue"); then
    echo "  cc-channel-unavailable: no free port in $CC_PORT_RANGE_START-$CC_PORT_RANGE_END" >&2
    return 1
  fi

  # Fresh UUID per spawn. cc_uuid_for_issue is deterministic (md5 of
  # issue id) which collides on re-spawn: the JSONL transcript from
  # the prior spawn lives at ~/.claude/projects/<encoded-cwd>/<uuid>.jsonl
  # and claude refuses with "Session ID … is already in use" when a
  # new launch tries to bind the same uuid. Random per-spawn matches
  # how oc and cx allocate identities.
  uuid=$(cat /proc/sys/kernel/random/uuid)
  mcp_path=$(cc_write_mcp_config "$issue" "$port")

  local bypass; bypass="$(bypass_flag_for_harness claude)"
  local cmd; cmd=$(build_claude_channel_cmd "$bin" "$mcp_path" "$uuid" "$issue" "$bypass")
  if ! open_tmux "$wt_path" "$issue" "$cmd"; then
    cc_release_port "$port"
    return 1
  fi

  # Pre-warm the trust prompt for --dangerously-load-development-channels.
  # First-launch only; subsequent launches skip the dialog if user
  # already trusted. Sending y/Enter after a small delay is harmless if
  # the prompt isn't there.
  (
    sleep 4
    local session; session=$(tmux display-message -p '#S' 2>/dev/null || echo HT)
    tmux send-keys -t "${session}:${issue}" "y" 2>/dev/null || true
    sleep 0.3
    tmux send-keys -t "${session}:${issue}" Enter 2>/dev/null || true
  ) &
  disown 2>/dev/null || true

  local spawn_file abs_wt transcript
  spawn_file=$(cc_spawn_file "$issue")
  abs_wt=$(cd "$wt_path" && pwd)
  transcript=$(cc_transcript_path "$wt_path" "$uuid")
  jq -nc \
    --arg url "http://127.0.0.1:$port" \
    --arg uuid "$uuid" \
    --arg dir "$abs_wt" \
    --arg transcript "$transcript" \
    --arg mcp "$mcp_path" \
    --argjson port "$port" \
    --arg ts "$(date -Iseconds)" \
    '{url:$url, session_uuid:$uuid, directory:$dir, transcript:$transcript, mcp_config:$mcp, port:$port, allocated_at:$ts}' \
    > "$spawn_file"

  echo "  cc-channel: port=$port uuid=$uuid transcript=$transcript"
  return 0
}

# --- pi Session Bridge adapter (Phase 3) -------------------------------------
#
# Pi spawns normally with the bridge package auto-loading via the
# vstack-installed pi config. After spawn, we poll `pi-bridge list`
# for the new bridge entry whose cwd matches the worktree, then
# persist {pid, socket, sessionId} to pi_spawn_file($issue) for
# pane-registry / pane-respond / pane-poll / daemon to discover.
#
# No port allocation — pi uses a Unix socket per process. No server-
# pid tracking (pi IS the bridge holder).

spawn_pi_bridge_tmux() {
  local issue="$1" wt_path="$2"
  local pi_bin
  if ! pi_bin=$(pi_resolve_pi_bin); then
    echo "  pi-bridge-unavailable: pi binary not found" >&2
    return 1
  fi
  if ! pi_resolve_bridge_bin >/dev/null; then
    echo "  pi-bridge-unavailable: pi-bridge CLI not found (PATH or ~/.pi/agent/bin/pi-bridge)" >&2
    return 1
  fi
  local ext_path
  if ! ext_path=$(pi_resolve_bridge_extension); then
    echo "  pi-bridge-unavailable: session-bridge extension not found at ~/.pi/agent/packages/pi-session-bridge/extensions/session-bridge.ts" >&2
    return 1
  fi

  # Spawn pi with explicit `-e <ext>` so the bridge always auto-loads,
  # regardless of whether the package is registered in settings.json's
  # packages array (the array can drift; -e is deterministic).
  local cmd; cmd="$pi_bin -e $ext_path '/orchestration start $issue'"
  if ! open_tmux "$wt_path" "$issue" "$cmd"; then
    return 1
  fi

  # Discover the new pi pid by cwd match.
  local pid
  if ! pid=$(pi_discover_pid "$wt_path" 30); then
    echo "  pi-bridge-unavailable: bridge discovery timed out (no pi instance with matching cwd)" >&2
    # The pane is already open; pane-respond / pane-poll will fall
    # through to tmux send-keys / capture-pane via the standard
    # fallback contract.
    return 1
  fi

  # Read state to capture sessionId + socket.
  local bridge_bin; bridge_bin=$(pi_resolve_bridge_bin)
  local state; state=$("$bridge_bin" state --pid "$pid" 2>/dev/null)
  local socket_path session_id
  socket_path=$(jq -r '.data.socketPath // ""' <<< "$state" 2>/dev/null)
  session_id=$(jq -r '.data.sessionId // ""' <<< "$state" 2>/dev/null)

  local spawn_file abs_wt
  spawn_file=$(pi_spawn_file "$issue")
  abs_wt=$(cd "$wt_path" && pwd)
  jq -nc \
    --argjson pid "$pid" \
    --arg socket "$socket_path" \
    --arg session_id "$session_id" \
    --arg dir "$abs_wt" \
    --arg ts "$(date -Iseconds)" \
    '{pid:$pid, socket:$socket, session_id:$session_id, directory:$dir, allocated_at:$ts}' \
    > "$spawn_file"

  echo "  pi-bridge: pid=$pid socket=$socket_path session=$session_id"
  return 0
}

# --- Codex app-server + --remote adapter (Phase 4) --------------------------
#
# ONE app-server per flightdeck session, hosted in a dedicated tmux
# window via codex-app-server-spawn (idempotent). Each per-pane
# `codex --remote ws://...` TUI registers as a thread; we discover
# the thread id via `bridge list` after the TUI's own thread shows up.

spawn_cx_remote_tmux() {
  local issue="$1" wt_path="$2"
  local cx_bin
  if ! cx_bin=$(cx_resolve_codex_bin); then
    echo "  cx-bridge-unavailable: codex binary not found" >&2
    return 1
  fi
  if ! cx_resolve_bun_bin >/dev/null; then
    echo "  cx-bridge-unavailable: bun not found (needed for codex-bridge)" >&2
    return 1
  fi

  local ws_url
  if ! ws_url=$("$SCRIPT_DIR/codex-app-server-spawn" 2>&1); then
    echo "  cx-bridge-unavailable: codex-app-server-spawn failed: $ws_url" >&2
    return 1
  fi

  # Snapshot existing thread set BEFORE spawning the TUI so we can pick
  # out only the new thread this spawn registers. Earlier impl used
  # `arr | last` and broke when a 2nd codex pane spawned: the loop saw
  # the prior pane's thread and exited before the new pane's thread had
  # registered, so both panes' spawn files ended up pointing at thread #1.
  local pre_threads_json
  pre_threads_json=$(cx_bridge_run list --url "$ws_url" 2>/dev/null \
    | jq -c '
        ( .data // .items // .threads // [] )
        | map(if type == "string" then . else (.threadId // .id // empty) end)
        | map(select(. != null and . != ""))
      ' 2>/dev/null)
  : "${pre_threads_json:=[]}"

  # Spawn the per-pane TUI bound to the shared server.
  local cmd; cmd="$cx_bin --remote $ws_url"
  if ! open_tmux "$wt_path" "$issue" "$cmd"; then
    return 1
  fi

  # Discover the thread id this TUI registered with by polling for a
  # thread present now but absent from the pre-spawn snapshot.
  local thread_id="" deadline=$((SECONDS + 30))
  while (( SECONDS < deadline )); do
    local list_out
    list_out=$(cx_bridge_run list --url "$ws_url" 2>/dev/null || echo "")
    if [[ -n "$list_out" ]]; then
      thread_id=$(jq -r --argjson pre "$pre_threads_json" '
        ( .data // .items // .threads // [] )
        | map(if type == "string" then . else (.threadId // .id // empty) end)
        | map(select(. != null and . != ""))
        | (. - $pre)
        | first // empty
      ' <<< "$list_out" 2>/dev/null)
      if [[ -n "$thread_id" && "$thread_id" != "null" ]]; then break; fi
    fi
    sleep 1
  done
  if [[ -z "$thread_id" || "$thread_id" == "null" ]]; then
    echo "  cx-bridge-unavailable: thread discovery timed out for $issue (no new thread on $ws_url after spawn)" >&2
    return 1
  fi

  local spawn_file abs_wt
  spawn_file=$(cx_spawn_file "$issue")
  abs_wt=$(cd "$wt_path" && pwd)
  jq -nc \
    --arg url "$ws_url" \
    --arg thread_id "$thread_id" \
    --arg dir "$abs_wt" \
    --arg ts "$(date -Iseconds)" \
    '{url:$url, thread_id:$thread_id, directory:$dir, allocated_at:$ts}' \
    > "$spawn_file"

  echo "  cx-bridge: url=$ws_url thread=$thread_id"
  return 0
}

# --- Terminal launchers -------------------------------------------------------

# Pre-trust directory in Claude Code config so the trust dialog is skipped
pretrust_claude_dir() {
  local dir="$1"
  local claude_json="${CLAUDE_CONFIG_DIR:+$CLAUDE_CONFIG_DIR/claude.json}"
  claude_json="${claude_json:-$HOME/.claude.json}"
  if [[ -f "$claude_json" ]]; then
    local abs_dir
    abs_dir="$(cd "$dir" && pwd)"
    if ! jq -e --arg p "$abs_dir" '.projects[$p].hasTrustDialogAccepted' "$claude_json" >/dev/null 2>&1; then
      local tmp_json
      tmp_json=$(mktemp)
      jq --arg p "$abs_dir" '.projects[$p] = (.projects[$p] // {}) + {hasTrustDialogAccepted: true}' "$claude_json" > "$tmp_json" && mv "$tmp_json" "$claude_json"
    fi
  fi
}

open_tmux() {
  local dir="$1" name="$2" cmd="$3"
  if [[ -z "${TMUX:-}" ]]; then
    echo "Error: not inside a tmux session" >&2
    return 1
  fi
  local last_idx
  last_idx=$(tmux list-windows -F '#{window_index}' | tail -1)
  tmux new-window -a -t ":${last_idx}" -n "$name" -c "$dir"
  tmux send-keys "clear" Enter
  if [[ -n "$cmd" ]]; then
    tmux send-keys -l "$cmd"
    tmux send-keys Enter
  fi
  echo "  Opened tmux window '$name' in $dir"
}

open_gui() {
  local dir="$1" title="$2" cmd="$3"
  local shell_cmd
  if [[ -n "$cmd" ]]; then
    shell_cmd="cd '$dir' && $cmd"
  else
    shell_cmd="cd '$dir'; exec \$SHELL"
  fi

  if [[ "$OSTYPE" == "darwin"* ]]; then
    if [[ -d "/Applications/Ghostty.app" ]]; then
      local args=(--working-directory="$dir")
      [[ -n "$title" ]] && args+=(--title="$title")
      if [[ -n "$cmd" ]]; then
        open -na "Ghostty.app" --args "${args[@]}" --command="$cmd"
      else
        open -na "Ghostty.app" --args "${args[@]}"
      fi
    elif command -v open &>/dev/null; then
      if [[ -n "$cmd" ]]; then
        osascript -e "tell application \"Terminal\" to do script \"cd '$dir' && $cmd\""
      else
        open -a Terminal "$dir"
      fi
    else
      echo "Error: no supported terminal emulator found on macOS" >&2
      return 1
    fi
  elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
    if command -v ghostty &>/dev/null; then
      local args=(--working-directory="$dir")
      [[ -n "$title" ]] && args+=(--title="$title")
      if [[ -n "$cmd" ]]; then
        setsid env -u CLAUDECODE ghostty "${args[@]}" -e bash -c "$shell_cmd" </dev/null &>/dev/null &
      else
        setsid env -u CLAUDECODE ghostty "${args[@]}" </dev/null &>/dev/null &
      fi
    elif command -v xdg-terminal-exec &>/dev/null; then
      setsid env -u CLAUDECODE xdg-terminal-exec bash -c "$shell_cmd" </dev/null &>/dev/null &
    elif command -v xterm &>/dev/null; then
      local xargs=()
      [[ -n "$title" ]] && xargs+=(-T "$title")
      setsid env -u CLAUDECODE xterm "${xargs[@]}" -e bash -c "$shell_cmd" </dev/null &>/dev/null &
    else
      echo "Error: no supported terminal emulator found" >&2
      return 1
    fi
  else
    echo "Error: unsupported platform: $OSTYPE" >&2
    return 1
  fi
  echo "  Opened terminal for $title in $dir"
}

# --- Main loop ----------------------------------------------------------------

if [[ ${#ISSUES[@]} -eq 1 ]]; then
  echo "Launching worktree (${TERMINAL_MODE})..."
else
  echo "Launching ${#ISSUES[@]} worktrees (${TERMINAL_MODE})..."
fi

LAUNCHED=0
FAILED=()

for ISSUE in "${ISSUES[@]}"; do
  # Create worktree (reuses existing) — capture stderr separately
  _wt_err=$(mktemp)
  if ! WT_PATH=$("$WORKTREE_CLI" create "$ISSUE" 2>"$_wt_err"); then
    echo "  Failed to create worktree: $(cat "$_wt_err")" >&2
    rm -f "$_wt_err"
    FAILED+=("$ISSUE")
    continue
  fi
  rm -f "$_wt_err"

  # Only pretrust for Claude harness
  if command -v claude &>/dev/null; then
    pretrust_claude_dir "$WT_PATH"
  fi

  # Opencode HTTP-attach (tmux mode only): allocate a port, spawn with
  # --port + bootstrap prompt, discover the session id, persist for
  # pane-registry. Falls back to legacy spawn on any adapter failure so
  # the pane still launches — pane-respond / pane-poll detect the absent
  # spawn file and use the tmux send-keys / capture-pane fallback path.
  if [[ "$TERMINAL_MODE" == "tmux" && "$HARNESS" == "opencode" && -z "$CMD_TEMPLATE" ]]; then
    if spawn_oc_attach_tmux "$ISSUE" "$WT_PATH"; then
      LAUNCHED=$((LAUNCHED + 1))
      continue
    fi
    # fall through to legacy spawn below
  fi

  # Claude Channels (Phase 2; opt-in via FLIGHTDECK_CLAUDE_CHANNELS=1
  # or --use-channels). Allocates a channel port, writes per-pane
  # .mcp.json, spawns claude with --session-id + --mcp-config +
  # --dangerously-load-development-channels. Falls back to legacy
  # spawn on any failure (claude < 2.1.80, wrong auth, no bun, port
  # exhausted, etc.) — pane stays launched, just on tmux-fallback.
  if [[ "$TERMINAL_MODE" == "tmux" && "$HARNESS" == "claude" && -z "$CMD_TEMPLATE" \
        && "$USE_CHANNELS" == "1" ]]; then
    if spawn_cc_channel_tmux "$ISSUE" "$WT_PATH"; then
      LAUNCHED=$((LAUNCHED + 1))
      continue
    fi
    # fall through to legacy spawn below
  fi

  # Pi Session Bridge (Phase 3). Pi-extension is global (vstack
  # installs pi-session-bridge to ~/.pi/agent/packages/) and auto-
  # loads on every pi process. After tmux opens the pi window, we
  # poll pi-bridge list to discover the new pid + socket, then write
  # spawn metadata. On any failure (no pi/pi-bridge, discovery
  # timeout) — fall through to legacy spawn (pi without bridge data
  # = tmux send-keys/capture-pane fallback).
  if [[ "$TERMINAL_MODE" == "tmux" && "$HARNESS" == "pi" && -z "$CMD_TEMPLATE" ]]; then
    if spawn_pi_bridge_tmux "$ISSUE" "$WT_PATH"; then
      LAUNCHED=$((LAUNCHED + 1))
      continue
    fi
    # fall through
  fi

  # Codex app-server + --remote (Phase 4). Idempotent server bring-up
  # (one per flightdeck session, in its own tmux window), per-pane
  # `codex --remote ws://...` TUI, thread-id discovery via the
  # vendored bun bridge. Falls through on any failure.
  if [[ "$TERMINAL_MODE" == "tmux" && "$HARNESS" == "codex" && -z "$CMD_TEMPLATE" ]]; then
    if spawn_cx_remote_tmux "$ISSUE" "$WT_PATH"; then
      LAUNCHED=$((LAUNCHED + 1))
      continue
    fi
    # fall through
  fi

  START_CMD=$(detect_start_cmd "$ISSUE")

  if [[ "$TERMINAL_MODE" == "tmux" ]]; then
    open_tmux "$WT_PATH" "$ISSUE" "$START_CMD"
  else
    open_gui "$WT_PATH" "$ISSUE" "$START_CMD"
  fi
  LAUNCHED=$((LAUNCHED + 1))
done

if [[ ${#FAILED[@]} -gt 0 ]]; then
  echo "Launched $LAUNCHED, failed ${#FAILED[@]}: ${FAILED[*]}" >&2
  exit 1
fi

echo "Done — $LAUNCHED worktree(s) launched."
