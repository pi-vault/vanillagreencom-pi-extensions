#!/usr/bin/env bash
# Poll a single tracked window — read bell flag, capture pane 0, classify.
#
# Outputs a single JSON object describing the window's current observable
# state. Intended to be called per-tracked-window in the watch loop.
#
# Usage:
#   pane-poll <window-target> [<pane-index>] [--harness <h>] [--worktree <path>] [--pr <N>]
#   pane-poll HT:cc-463
#   pane-poll HT:cc-463 0 --harness opencode
#   pane-poll HT:cc-463 0 --harness opencode --worktree trees/cc-463 --pr 463
#
# When --worktree and --pr are both passed and the worktree directory is
# gone AND `gh pr view <PR>` returns MERGED, the tag is forced to
# terminal-state-reached even if the classifier didn't recognize the
# orchestrator's end-of-flow text. Defense-in-depth for the lifecycle.
#
# JSON fields:
#   {
#     "window": "HT:cc-463",
#     "pane_target": "HT:cc-463.0",
#     "bell": true|false,
#     "activity": true|false,
#     "silence": true|false,
#     "tag": "rebase-multi-choice" | "rendering" | "idle" | ...,
#     "capture_hash": "sha256:...",
#     "fingerprint_match": true|false,    # registered pane still hosts the orchestrator
#     "pane_index_suggest": null|<idx>     # if mismatch, sibling pane that matched
#   }
#
# Exit codes:
#   0 - success (window exists, captured, classified)
#   1 - window not found
#   2 - bad arguments / not in tmux
set -euo pipefail

if [[ -z "${TMUX:-}" ]]; then
  echo "Error: not inside a tmux session" >&2
  exit 2
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=lib/oc-paths.sh
source "$SCRIPT_DIR/lib/oc-paths.sh"

TARGET="${1:-}"
if [[ -z "$TARGET" ]]; then
  echo "Usage: pane-poll <window-target>" >&2
  exit 2
fi

# Optional: pinned pane index (default 0)
PANE_INDEX="${2:-0}"
shift || true; shift || true

HARNESS=""
WORKTREE=""
PR=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --harness) HARNESS="$2"; shift 2 ;;
    --harness=*) HARNESS="${1#--harness=}"; shift ;;
    --worktree) WORKTREE="$2"; shift 2 ;;
    --worktree=*) WORKTREE="${1#--worktree=}"; shift ;;
    --pr) PR="$2"; shift 2 ;;
    --pr=*) PR="${1#--pr=}"; shift ;;
    *) shift ;;
  esac
done

PANE_TARGET="${TARGET}.${PANE_INDEX}"

CAPTURE_ARGS=(-p -S -200)

# Verify window exists; emit dead state if not.
if ! tmux list-windows -t "${TARGET%:*}" -F '#{window_index}:#{window_name}' 2>/dev/null \
     | awk -F: -v w="${TARGET#*:}" '$2 == w {found=1} END {exit !found}'; then
  jq -n --arg w "$TARGET" --arg p "$PANE_TARGET" '{window:$w, pane_target:$p, dead:true, tag:"dead"}'
  exit 0
fi

# Read window flags
flags_line=$(tmux list-windows -t "${TARGET%:*}" \
  -F '#{window_name}|#{window_bell_flag}|#{window_activity_flag}|#{window_silence_flag}' 2>/dev/null \
  | awk -F'|' -v w="${TARGET#*:}" '$1 == w {print; exit}')

bell=$(awk -F'|' '{print $2}' <<< "$flags_line")
activity=$(awk -F'|' '{print $3}' <<< "$flags_line")
silence=$(awk -F'|' '{print $4}' <<< "$flags_line")

# Capture and classify. For opencode panes with HTTP-attach metadata in
# the registry, fetch the message log via the adapter and classify the
# last assistant text. Drops tmux capture-pane for those panes entirely
# — no scrollback, no OSC leak, no ANSI noise.
#
# Adapter-mode commitment: once oc-attach metadata is present, we COMMIT
# to the adapter. curl failure surfaces as an empty buffer (classifier
# returns idle/rendering); we never silently fall back to tmux scrollback,
# which would re-introduce the rendered-buffer noise the adapter exists
# to bypass. The fallback path runs only when oc-attach metadata is
# absent (legacy session, port exhausted, adapter not wired).
buf=""
oc_used=0
if [[ "$HARNESS" == "opencode" ]]; then
  oc_issue=$("$SCRIPT_DIR/pane-registry" find-by-pane "$PANE_TARGET" 2>/dev/null || echo "")
  oc_attach_args=""
  if [[ -n "$oc_issue" ]]; then
    oc_attach_args=$("$SCRIPT_DIR/pane-registry" oc-attach-args "$oc_issue" 2>/dev/null || echo "")
  fi
  # Fallback: registry init may not have run yet for this pane. Derive
  # issue from the window name and read the spawn file directly so the
  # adapter still drives polling. Symmetric with pane-respond.
  if [[ -z "$oc_attach_args" ]]; then
    derived_issue=$(oc_issue_from_pane_target "$PANE_TARGET")
    if [[ -n "$derived_issue" ]]; then
      oc_attach_args=$(oc_attach_args_from_spawn "$derived_issue" 2>/dev/null || echo "")
    fi
  fi
  if [[ -n "$oc_attach_args" ]]; then
    oc_used=1
    oc_url=$(awk '{for(i=1;i<=NF;i++)if($i=="--url"){print $(i+1);exit}}' <<< "$oc_attach_args")
    oc_session=$(awk '{for(i=1;i<=NF;i++)if($i=="--session"){print $(i+1);exit}}' <<< "$oc_attach_args")
    resp=$(curl -s --max-time 5 "$oc_url/session/$oc_session/message" 2>/dev/null || echo "")
    if [[ -n "$resp" ]]; then
      buf=$(jq -r "$OC_LAST_ASSISTANT_JQ" <<< "$resp" 2>/dev/null || echo "")
    fi
  fi
fi

if [[ $oc_used -eq 0 ]]; then
  buf=$(tmux capture-pane -t "$PANE_TARGET" "${CAPTURE_ARGS[@]}" 2>/dev/null || echo "")
fi

capture_hash=$(printf '%s' "$buf" | sha256sum | awk '{print "sha256:"$1}')
# Adapter-mode input has no TUI footer; skip the footer gate so option-list
# / merge-now / etc. shapes classify correctly. Tmux-fallback path keeps
# the footer gate as a buffer-completeness signal.
if [[ $oc_used -eq 1 ]]; then
  tag=$(printf '%s' "$buf" | "$SCRIPT_DIR/prompt-classify" --no-footer-gate 2>/dev/null || echo "idle")
else
  tag=$(printf '%s' "$buf" | "$SCRIPT_DIR/prompt-classify" 2>/dev/null || echo "idle")
fi

# Orphan cross-check — when caller passes --worktree and --pr, synthesize
# terminal-state-reached if the worktree directory is gone AND the PR is
# merged. Defense-in-depth against the classifier missing the orchestrator's
# end-of-flow text (Round 4: 6 issues all merged + worktree-cleaned but the
# orchestrator's final summary screen didn't match terminal-state sentinels,
# so close-issue.md never ran and 6 windows piled up). Only runs when the
# pane's own buffer didn't already say terminal-state-reached.
if [[ "$tag" != "terminal-state-reached" && -n "$WORKTREE" && -n "$PR" ]]; then
  if [[ ! -d "$WORKTREE" ]]; then
    if command -v gh >/dev/null 2>&1; then
      pr_state=$(gh pr view "$PR" --json state --jq '.state' 2>/dev/null || echo "")
      if [[ "$pr_state" == "MERGED" ]]; then
        tag="terminal-state-reached"
      fi
    fi
  fi
fi

# Fingerprint check — confirm the registered pane still hosts the
# orchestrator TUI. If sub-agent panes were spawned and the orchestrator
# moved (unlikely but possible across compaction or harness restart), we
# emit fingerprint_match=false + pane_index_suggest with the actual index
# so the caller (watch.md) can update the registry. Only scans siblings
# when the registered pane fails the sentinel — keeps the common case
# cheap (one capture, one grep).
#
# Adapter-mode opencode skips this entirely: the session_id binds the
# data path to opencode's HTTP server, not to a tmux pane location.
fingerprint_match=true
pane_index_suggest=null
if [[ $oc_used -eq 0 ]]; then
  fingerprint_sentinel='❯ |claude code|opencode|codex>|■■■|⠋|⠙|⠸|⠴|⠦|⠧'
  if ! grep -qE "$fingerprint_sentinel" <<< "$buf"; then
    fingerprint_match=false
    while read -r idx; do
      [[ -z "$idx" || "$idx" == "$PANE_INDEX" ]] && continue
      sib_buf=$(tmux capture-pane -t "${TARGET}.${idx}" -p -S -50 2>/dev/null || echo "")
      if grep -qE "$fingerprint_sentinel" <<< "$sib_buf"; then
        pane_index_suggest="$idx"
        break
      fi
    done < <(tmux list-panes -t "$TARGET" -F '#{pane_index}' 2>/dev/null)
  fi
fi

jq -n \
  --arg window "$TARGET" \
  --arg pane "$PANE_TARGET" \
  --argjson bell "$([ "${bell:-0}" = "1" ] && echo true || echo false)" \
  --argjson activity "$([ "${activity:-0}" = "1" ] && echo true || echo false)" \
  --argjson silence "$([ "${silence:-0}" = "1" ] && echo true || echo false)" \
  --arg tag "$tag" \
  --arg capture_hash "$capture_hash" \
  --argjson fingerprint_match "$fingerprint_match" \
  --argjson pane_index_suggest "$pane_index_suggest" \
  '{
    window: $window,
    pane_target: $pane,
    bell: $bell,
    activity: $activity,
    silence: $silence,
    tag: $tag,
    capture_hash: $capture_hash,
    fingerprint_match: $fingerprint_match,
    pane_index_suggest: $pane_index_suggest
  }'
