#!/usr/bin/env bash
# Phase 1 smoke test — opencode HTTP-attach adapter, two-step launch.
#
# Verifies:
#   - port allocator
#   - `opencode serve --port` background spawn + readiness probe
#   - session creation via `opencode run --attach <URL> --agent build
#     --format json "<bootstrap>"` — captures sessionID from NDJSON
#   - tmux `opencode attach <URL> --session <SID>` window opens
#   - session permission JSON denies the question tool (modal-escape
#     hatch is closed at session-creation time; this is the whole point
#     of the two-step launch)
#   - follow-up `opencode run --attach <URL> --session <SID>` echoes
#     SMOKE-OK with `step_finish reason=stop` in the event stream
#   - GET /session/<id>/message returns user + assistant pair
#   - port released, server killed on teardown
#
# Assertions never use `tmux send-keys` or `tmux capture-pane`. The
# tmux window from step 2 is for visualization only; the adapter
# contract is verified entirely via HTTP + the opencode CLI.
#
# Requires: $TMUX set, /usr/bin/opencode (or opencode in PATH that
# isn't an alias), curl, jq, flock.

set -euo pipefail

TEST_NAME="opencode-attach-smoke"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
SCRIPTS="$SKILL_DIR/scripts"

# shellcheck source=../scripts/lib/oc-paths.sh
source "$SCRIPTS/lib/oc-paths.sh"

red()    { printf '\033[31m%s\033[0m\n' "$*" >&2; }
green()  { printf '\033[32m%s\033[0m\n' "$*"; }
note()   { printf '  %s\n' "$*"; }
warn()   { printf '\033[33m  %s\033[0m\n' "$*" >&2; }
fail()   { red "FAIL[$TEST_NAME]: $*"; cleanup; exit 1; }

# --- Preflight ---------------------------------------------------------------
[[ -z "${TMUX:-}" ]] && fail "must run inside a tmux session"
for cmd in curl jq flock sha256sum; do
  command -v "$cmd" >/dev/null 2>&1 || fail "missing required cmd: $cmd"
done
OC_BIN=""
if [[ -x /usr/bin/opencode ]]; then
  OC_BIN=/usr/bin/opencode
else
  OC_BIN=$(type -P opencode 2>/dev/null || true)
fi
[[ -z "$OC_BIN" || ! -x "$OC_BIN" ]] && fail "opencode binary not found (PATH or /usr/bin)"

# --- Isolation ---------------------------------------------------------------
TEST_TMPDIR=$(mktemp -d -t fd-oc-smoke-XXXXXX)
WORKTREE="$TEST_TMPDIR/worktree"
mkdir -p "$WORKTREE"
ABS_WORKTREE=$(cd "$WORKTREE" && pwd)

export FD_STATE_DIR="$TEST_TMPDIR/state"
mkdir -p "$FD_STATE_DIR"
chmod 0700 "$FD_STATE_DIR"

ISSUE="SMOKE-TEST-1"
WINDOW_NAME="oc-smoke-$$"
TEST_WINDOW=""
ALLOCATED_PORT=""
SERVER_PID=""

cleanup() {
  if [[ -n "$TEST_WINDOW" ]]; then
    tmux kill-window -t "$TEST_WINDOW" 2>/dev/null || true
  fi
  if [[ -n "$SERVER_PID" ]] && kill -0 "$SERVER_PID" 2>/dev/null; then
    # opencode serve forks; kill the whole pgroup (PGID == SERVER_PID
    # because we used setsid). Escalate to KILL if TERM is ignored.
    kill -- -"$SERVER_PID" 2>/dev/null || kill "$SERVER_PID" 2>/dev/null || true
    for _i in 1 2 3 4 5; do
      kill -0 "$SERVER_PID" 2>/dev/null || break
      sleep 0.2
    done
    if kill -0 "$SERVER_PID" 2>/dev/null; then
      kill -9 -- -"$SERVER_PID" 2>/dev/null || kill -9 "$SERVER_PID" 2>/dev/null || true
    fi
    # Reap the zombie. SERVER_PID is a child of this shell (setsid +
    # nohup detaches the controlling terminal but doesn't change the
    # parent), so kill -0 returns 0 for the zombie state until we
    # wait() for it. Without the wait, the post-cleanup `kill -0`
    # check sees the zombie and reports "still alive".
    wait "$SERVER_PID" 2>/dev/null || true
  fi
  if [[ -n "$ALLOCATED_PORT" ]]; then
    oc_release_port "$ALLOCATED_PORT" 2>/dev/null || true
  fi
  rm -rf "$TEST_TMPDIR"
}
trap cleanup EXIT INT TERM

# --- Step 1: allocate port + spawn opencode serve ---------------------------
note "step 1: allocate port + spawn opencode serve"
ALLOCATED_PORT=$(oc_alloc_port "$ISSUE") || fail "oc_alloc_port returned non-zero"
[[ "$ALLOCATED_PORT" =~ ^[0-9]+$ ]] || fail "allocated port not numeric: $ALLOCATED_PORT"
note "  port=$ALLOCATED_PORT"

SERVER_LOG=$(oc_server_log "$ALLOCATED_PORT")
setsid nohup "$OC_BIN" serve --port "$ALLOCATED_PORT" --hostname 127.0.0.1 \
  </dev/null >>"$SERVER_LOG" 2>&1 &
SERVER_PID=$!
note "  server_pid=$SERVER_PID log=$SERVER_LOG"

deadline=$((SECONDS + 15))
SERVER_UP=0
while (( SECONDS < deadline )); do
  if curl -s --max-time 2 -o /dev/null -w '%{http_code}' \
      "http://127.0.0.1:$ALLOCATED_PORT/session" 2>/dev/null \
      | grep -qE '^(200|404)$'; then
    SERVER_UP=1
    break
  fi
  if ! kill -0 "$SERVER_PID" 2>/dev/null; then
    fail "opencode serve exited prematurely; tail of log: $(tail -n 5 "$SERVER_LOG" 2>/dev/null)"
  fi
  sleep 0.5
done
(( SERVER_UP == 1 )) || fail "opencode serve health timed out on port $ALLOCATED_PORT"
note "  server up"

URL="http://127.0.0.1:$ALLOCATED_PORT"

# --- Step 2: create session via run --attach (--agent build) ----------------
note "step 2: create session via opencode run --attach (capture sessionID)"
CREATE_OUT=$(timeout 60 "$OC_BIN" run --attach "$URL" \
              --agent build --format json \
              "respond literally with READY-CHECK and nothing else" 2>&1) \
  || fail "opencode run --attach (session create) exit non-zero; output: $CREATE_OUT"

SESSION_ID=$(printf '%s\n' "$CREATE_OUT" \
  | jq -r 'select(.sessionID // .session_id // .sessionId) | (.sessionID // .session_id // .sessionId)' 2>/dev/null \
  | head -n 1)
[[ -z "$SESSION_ID" || "$SESSION_ID" == "null" ]] \
  && fail "could not parse sessionID from create output: $(printf '%s\n' "$CREATE_OUT" | head -n 10)"
note "  session_id=$SESSION_ID"

# --- Step 3: assert session permission denies the question tool -------------
# Verified shape (opencode 1.14.26): /session/<id> returns
# {... "permission":[{"permission":"question","pattern":"*","action":"deny"},
#                    {"permission":"plan_enter", ..., "action":"deny"}, ...] ...}
# The deny entry is what closes the modal-escape hatch — without it the
# linear-orch agent can render question prompts that run --attach
# can't drive, breaking chat-text-only.
note "step 3: verify session permission denies question tool"
PERM_DENIES_QUESTION=0
PERM_PROBE_OUT=""
SESS_RESP=$(curl -s --max-time 5 "$URL/session/$SESSION_ID" 2>/dev/null || echo "")
if [[ -n "$SESS_RESP" ]] && jq -e . <<< "$SESS_RESP" >/dev/null 2>&1; then
  PERM_PROBE_OUT="$SESS_RESP"
  if jq -e '
    [(.permission // []) | .[]]
    | any(.permission == "question" and (.action // "" | ascii_downcase) == "deny")
  ' <<< "$SESS_RESP" >/dev/null 2>&1; then
    PERM_DENIES_QUESTION=1
  fi
fi
if (( PERM_DENIES_QUESTION == 0 )); then
  red "  permission JSON does not deny question tool — modal-escape OPEN"
  red "  probe: $(printf '%s' "$PERM_PROBE_OUT" | head -c 400)"
  fail "session permission missing {question, action: deny} — agent could render modal UI"
fi
note "  permission denies question (modal-escape closed)"

# --- Step 4: open visible TUI in tmux window via opencode attach ------------
note "step 4: open visible TUI in tmux via opencode attach"
ATTACH_CMD=$(printf "%s attach %s --session %s" "$OC_BIN" "$URL" "$SESSION_ID")
SESSION_NAME=$(tmux display-message -p '#S')
LAST_IDX=$(tmux list-windows -t "$SESSION_NAME" -F '#{window_index}' | tail -1)
tmux new-window -d -a -t "${SESSION_NAME}:${LAST_IDX}" -n "$WINDOW_NAME" \
  -c "$ABS_WORKTREE" "$ATTACH_CMD"
TEST_WINDOW="${SESSION_NAME}:${WINDOW_NAME}"
note "  tmux window=$TEST_WINDOW"

# --- Step 5: follow-up run --attach with SMOKE-OK assertion -----------------
note "step 5: follow-up run --attach asserts SMOKE-OK + step_finish reason=stop"
ATTACH_OUT=$(timeout 60 "$OC_BIN" run --attach "$URL" \
              --session "$SESSION_ID" --format json \
              "respond literally with the text SMOKE-OK and nothing else" 2>&1) \
  || fail "opencode run --attach (follow-up) exit non-zero: $ATTACH_OUT"

if ! grep -qE '"type"\s*:\s*"step_finish"|"reason"\s*:\s*"stop"' <<< "$ATTACH_OUT"; then
  red "  no step_finish reason=stop in event stream:"
  printf '%s\n' "$ATTACH_OUT" | head -n 30 >&2
  fail "step_finish/reason=stop missing from event stream"
fi
if ! grep -q "SMOKE-OK" <<< "$ATTACH_OUT"; then
  red "  SMOKE-OK not echoed in event stream:"
  printf '%s\n' "$ATTACH_OUT" | head -n 30 >&2
  fail "assistant did not echo SMOKE-OK"
fi
note "  step_finish + SMOKE-OK observed"

# --- Step 6: GET /session/<id>/message contains user + assistant ------------
note "step 6: GET /session/$SESSION_ID/message contains user + assistant"
MSG=$(curl -s --max-time 5 "$URL/session/$SESSION_ID/message" 2>/dev/null || echo "")
[[ -z "$MSG" ]] && fail "/session/<id>/message returned empty"

USER_PRESENT=$(jq -r '
  ( . // [] )
  | ( if type == "object" then (.messages // .data // .items // []) else . end )
  | map(select(((.info.role // .role // .message.role) // "") == "user")) | length
' <<< "$MSG" 2>/dev/null || echo "0")
ASSISTANT_PRESENT=$(jq -r '
  ( . // [] )
  | ( if type == "object" then (.messages // .data // .items // []) else . end )
  | map(select(((.info.role // .role // .message.role) // "") == "assistant")) | length
' <<< "$MSG" 2>/dev/null || echo "0")
(( USER_PRESENT >= 1 ))      || fail "no user message in /message response"
(( ASSISTANT_PRESENT >= 1 )) || fail "no assistant message in /message response"
note "  user_count=$USER_PRESENT assistant_count=$ASSISTANT_PRESENT"

# --- Step 7: extract last assistant text via the production jq filter -------
note "step 7: OC_LAST_ASSISTANT_JQ extracts non-empty assistant text"
LAST_TEXT=$(jq -r "$OC_LAST_ASSISTANT_JQ" <<< "$MSG" 2>/dev/null || echo "")
[[ -z "$LAST_TEXT" ]] && fail "OC_LAST_ASSISTANT_JQ returned empty"
note "  last_text length=${#LAST_TEXT}"

# --- Step 8: teardown -------------------------------------------------------
note "step 8: kill TUI window + server + release port"
tmux kill-window -t "$TEST_WINDOW" 2>/dev/null || true
TEST_WINDOW=""
# Reap pgroup; opencode serve forks. Escalate to KILL on stragglers.
kill -- -"$SERVER_PID" 2>/dev/null || kill "$SERVER_PID" 2>/dev/null || true
for _i in 1 2 3 4 5; do
  kill -0 "$SERVER_PID" 2>/dev/null || break
  sleep 0.2
done
if kill -0 "$SERVER_PID" 2>/dev/null; then
  kill -9 -- -"$SERVER_PID" 2>/dev/null || kill -9 "$SERVER_PID" 2>/dev/null || true
fi
# Reap the zombie before the alive-check; otherwise kill -0 returns 0
# for the zombie state (process exists in kernel until wait()).
wait "$SERVER_PID" 2>/dev/null || true
# Final check: now we expect the pid to be entirely gone.
if kill -0 "$SERVER_PID" 2>/dev/null; then
  # If still observable here, check /proc to distinguish zombie from running.
  if [[ -r "/proc/$SERVER_PID/status" ]]; then
    state=$(awk '/^State:/ {print $2}' "/proc/$SERVER_PID/status" 2>/dev/null || echo "?")
    [[ "$state" != "Z" ]] && fail "server pid=$SERVER_PID still alive (state=$state) after escalated kill"
  fi
fi
SERVER_PID=""
oc_release_port "$ALLOCATED_PORT"
PORTS_AFTER=$(jq -r --arg p "$ALLOCATED_PORT" 'has($p)' "$(oc_ports_file)" 2>/dev/null || echo "false")
[[ "$PORTS_AFTER" == "false" ]] || fail "port $ALLOCATED_PORT still present in ports file after release"
ALLOCATED_PORT=""
note "  cleanup done"

green "PASS[$TEST_NAME]"
