#!/usr/bin/env bash
# session-init — Initialize development session and display dashboard
# Usage: session-init         # formatted dashboard
#        session-init --json  # raw JSON for workflows

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILLS_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# Source .env.local for project config (ISSUE_PATTERN, GH_BOT_TOKEN, etc.)
ENV_FILE="$PROJECT_ROOT/.env.local"
if [[ -f "$ENV_FILE" ]]; then
  # shellcheck source=/dev/null
  source "$ENV_FILE"
fi

# Sibling skill scripts (resolved from install location)
LINEAR="$SKILLS_DIR/linear/scripts/linear.sh"
GITHUB="$SKILLS_DIR/github/scripts/github.sh"

OUTPUT_FORMAT="dashboard"
[[ "${1:-}" == "--json" ]] && OUTPUT_FORMAT="json"

json_or_default() {
  local fallback="$1"
  local expected_type="$2"
  shift 2

  local output=""
  if ! output=$("$@" 2>&1); then
    printf 'Command failed: %s\n' "$*" >&2
    if [[ -n "$output" ]]; then
      printf '%s\n' "$output" >&2
    fi
    printf '%s' "$fallback"
    return 1
  fi

  if ! jq -e --arg type "$expected_type" 'type == $type' >/dev/null 2>&1 <<<"$output"; then
    printf 'Invalid JSON response (expected %s): %s\n' "$expected_type" "$*" >&2
    if [[ -n "$output" ]]; then
      printf '%s\n' "$output" >&2
    fi
    printf '%s' "$fallback"
    return 2
  fi

  printf '%s' "$output"
}

curl_config_quote() {
  printf '%s' "$1" | jq -Rs .
}

# ─────────────────────────────────────────────────────────────────────────────
# Data Collection (silent)
# ─────────────────────────────────────────────────────────────────────────────

# Platform detection
if [[ "$OSTYPE" == "linux-gnu"* ]]; then
  PLATFORM="linux"
elif [[ "$OSTYPE" == "darwin"* ]]; then
  PLATFORM="macos"
elif [[ "$OSTYPE" == "msys" ]] || [[ "$OSTYPE" == "win32" ]] || [[ "$OSTYPE" == "cygwin" ]]; then
  PLATFORM="windows"
else
  PLATFORM="unknown"
fi

# Language/toolchain detection (auto-detect from project files)
LANG_VERSION=""
LANG_NAME=""
LANG_LSP=""
if [[ -f "$PROJECT_ROOT/Cargo.toml" ]]; then
  LANG_NAME="rust"
  LANG_VERSION=$(cargo --version 2>/dev/null | awk '{print $2}' || echo "")
  LANG_LSP="ok"; command -v rust-analyzer &>/dev/null || LANG_LSP="missing"
elif [[ -f "$PROJECT_ROOT/package.json" ]]; then
  LANG_NAME="node"
  LANG_VERSION=$(node --version 2>/dev/null | sed 's/^v//' || echo "")
  LANG_LSP="ok"; command -v typescript-language-server &>/dev/null || LANG_LSP="missing"
elif [[ -f "$PROJECT_ROOT/go.mod" ]]; then
  LANG_NAME="go"
  LANG_VERSION=$(go version 2>/dev/null | awk '{print $3}' | sed 's/^go//' || echo "")
  LANG_LSP="ok"; command -v gopls &>/dev/null || LANG_LSP="missing"
elif [[ -f "$PROJECT_ROOT/pyproject.toml" ]] || [[ -f "$PROJECT_ROOT/setup.py" ]]; then
  LANG_NAME="python"
  LANG_VERSION=$(python3 --version 2>/dev/null | awk '{print $2}' || echo "")
  LANG_LSP="ok"; command -v pyright &>/dev/null || command -v pylsp &>/dev/null || LANG_LSP="missing"
fi

BRANCH=$(git branch --show-current 2>/dev/null || echo "main")

# Worktree detection
IS_WORKTREE="false"
WORKTREE_NAME=""
GIT_COMMON_DIR=$(git rev-parse --git-common-dir 2>/dev/null || echo "")
if [[ -n "$GIT_COMMON_DIR" && "$GIT_COMMON_DIR" != ".git" && "$GIT_COMMON_DIR" != "$(pwd)/.git" ]]; then
  IS_WORKTREE="true"
  WORKTREE_NAME=$(basename "$(pwd)")
  # Fast path: worktree sessions skip full dashboard, check only auth + LSP
  WT_GH_OK="false"
  gh api user &>/dev/null && WT_GH_OK="true"
  if ! WT_LINEAR=$(json_or_default '{"ok":false,"error":"auth-check failed"}' object "$LINEAR" auth-check 2>/dev/null); then
    WT_LINEAR='{"ok":false,"error":"not installed"}'
  fi
  WT_LINEAR_OK=$(echo "$WT_LINEAR" | jq -r '.ok // false')
  WT_LINEAR_ERR=$(echo "$WT_LINEAR" | jq -r '.error // empty')

  if [[ "$OUTPUT_FORMAT" == "json" ]]; then
    jq -n \
      --arg worktree_name "$WORKTREE_NAME" \
      --argjson gh "$WT_GH_OK" \
      --argjson linear "$WT_LINEAR" \
      --arg lsp "${LANG_LSP:-}" \
      --arg platform "$PLATFORM" \
      --arg lang "$LANG_NAME" \
      --arg lang_version "$LANG_VERSION" \
      --arg branch "$BRANCH" \
      '{is_worktree: true, worktree_name: $worktree_name, platform: $platform, lang: $lang, lang_version: $lang_version, branch: $branch, gh_auth: $gh, linear_auth: $linear, lsp: $lsp}'
  else
    GH_ICON=$([[ "$WT_GH_OK" == "true" ]] && echo "✓" || echo "✗")
    LINEAR_ICON=$([[ "$WT_LINEAR_OK" == "true" ]] && echo "✓" || echo "✗")
    echo "\`Environment ──────────────────────────────────────────────\`"
    echo "$PLATFORM${LANG_VERSION:+ · $LANG_NAME $LANG_VERSION} · $BRANCH"
    echo "🌳 Worktree session · $WORKTREE_NAME"
    echo "GitHub: $GH_ICON · Linear: $LINEAR_ICON"
    [[ "$WT_GH_OK" != "true" ]] && echo "🔴 GitHub auth failed — run: gh auth login"
    [[ "$WT_LINEAR_OK" != "true" ]] && echo "🔴 Linear auth failed${WT_LINEAR_ERR:+ — $WT_LINEAR_ERR}"
  fi
  exit 0
fi

# ── Temp dir for parallel results ──
_tmp=$(mktemp -d)
trap 'rm -rf "$_tmp"' EXIT

# ── Phase 1: All independent operations in parallel ──

# Build check (auto-detect build tool)
{
  _bf=0
  if [[ -f "$PROJECT_ROOT/Cargo.toml" ]]; then
    cargo check --workspace &>/dev/null || _bf=1
  elif [[ -f "$PROJECT_ROOT/package.json" ]]; then
    (cd "$PROJECT_ROOT" && npm run --silent build 2>/dev/null) || _bf=1
  elif [[ -f "$PROJECT_ROOT/Makefile" ]]; then
    (cd "$PROJECT_ROOT" && make -q 2>/dev/null) || _bf=1
  else
    _bf=-1  # no build system detected
  fi
  echo "$_bf" >"$_tmp/build"
} &

# Git warnings
{
  _uc=0
  if git rev-parse --git-dir &>/dev/null && ! git diff-index --quiet HEAD 2>/dev/null; then
    _uc=$(git status --short 2>/dev/null | wc -l | tr -d ' ')
  fi
  echo "$_uc" >"$_tmp/uncommitted"

  _mw=$(pwd)
  _wp=$(git worktree list --porcelain 2>/dev/null | grep "^worktree " | sed 's/^worktree //' |
    grep -v "^${_mw}$" || true)
  if [[ -n "$_wp" ]]; then
    echo "$_wp" | jq -R . | jq -s . >"$_tmp/worktrees"
  else
    echo "[]" >"$_tmp/worktrees"
  fi
} &

# Linear session-status + parallel groups
{
  _ss_fallback='{"research":{"count":0,"unprocessed":[],"all_processed":true},"projects":[],"backlog_projects":[],"issues":{"actionable":[],"research_pending":[],"research_ready":[],"backlog":[],"blocked":[],"in_progress":[]},"pr_blockers":[]}'
  _ss="$_ss_fallback"
  if [[ -x "$LINEAR" ]]; then
    if ! _ss=$(json_or_default "$_ss_fallback" object "$LINEAR" session-status); then
      _ss="$_ss_fallback"
    fi
  fi
  echo "$_ss" >"$_tmp/linear"

  _pg="[]"
  _pc='{"needed":false}'
  if [[ -x "$SCRIPT_DIR/parallel-groups" ]]; then
    if ! _pg=$(json_or_default '[]' array "$SCRIPT_DIR/parallel-groups" read --all); then
      _pg='[]'
    fi
    while IFS= read -r _pn; do
      [[ -z "$_pn" ]] && continue
      _ids=$("$LINEAR" cache issues list --project "$_pn" --state "Todo" --format=ids 2>/dev/null || echo "")
      [[ -z "$_ids" ]] && continue
      _ic=$(echo "$_ids" | wc -l | tr -d ' ')
      [[ "$_ic" -lt 2 ]] && continue
      # shellcheck disable=SC2086
      _refresh_out=$("$SCRIPT_DIR/parallel-groups" needs-refresh $_ids 2>/dev/null) && {
        _raw=$(echo "$_refresh_out" | sed 's/^new: //')
        _n_uncovered=$(echo "$_raw" | tr ',' '\n' | wc -l | tr -d ' ')
        if [[ "$_n_uncovered" -gt 3 ]]; then
          _reason="$(echo "$_raw" | cut -d',' -f1-3 | sed 's/ not analyzed//') +$((_n_uncovered - 3)) more not analyzed"
        else
          _reason="$_raw"
        fi
        _pc=$(jq -n --arg project "$_pn" --argjson count "$_ic" --arg reason "$_reason" \
          '{needed: true, project: $project, count: $count, reason: $reason}')
        break
      }
    done <<<"$(echo "$_ss" | jq -r '.projects[] | select(.has_active_work) | .name' 2>/dev/null)"
  fi
  echo "$_pg" >"$_tmp/pgroups"
  echo "$_pc" >"$_tmp/pcheck"
} &

# GitHub auth + API check + bot token
{
  _gh_auth='{"available":false,"active_account":"","accounts":[]}'
  _can_api=false
  _gh_user=""

  if command -v gh &>/dev/null; then
    gh auth status --json hosts 2>/dev/null >"$_tmp/gh_auth_raw" &
    gh api user --jq '.login' 2>/dev/null >"$_tmp/gh_user_raw" &
    wait
    _auth_json=$(cat "$_tmp/gh_auth_raw" 2>/dev/null || echo '{"hosts":{}}')
    [[ -z "$_auth_json" ]] && _auth_json='{"hosts":{}}'
    _gh_user=$(cat "$_tmp/gh_user_raw" 2>/dev/null || echo "")

    _accounts=$(echo "$_auth_json" | jq '
   [.hosts["github.com"] // [] | .[] | {
    name: .login,
    status: (if .state == "success" then "ok" else "invalid" end),
    method: .gitProtocol,
    active: .active
   }]')
    _active=$(echo "$_accounts" | jq -r '[.[] | select(.active)] | .[0].name // ""')

    if [[ -n "$_gh_user" ]]; then _can_api=true; fi

    # Bot token check (from .env.local GH_BOT_TOKEN)
    _bt="${GH_BOT_TOKEN:-}"
    if [[ -n "$_bt" ]]; then
      # Support 1Password references
      if [[ "$_bt" == op://* ]] && command -v op &>/dev/null; then
        _bt=$(op read "$_bt" 2>/dev/null || echo "")
      fi
      if [[ -n "$_bt" ]]; then
        _bu=$(
          printf '%s\n' \
            "url = $(curl_config_quote "https://api.github.com/user")" \
            "header = $(curl_config_quote "Authorization: token $_bt")" \
          | curl -s -m 3 -K - 2>/dev/null | jq -r '.login // empty'
        )
        if [[ -n "$_bu" ]]; then
          _accounts=$(echo "$_accounts" | jq --arg acct "$_bu" '. + [{name: $acct, status: "ok", method: "token", source: "env"}]')
        else
          _accounts=$(echo "$_accounts" | jq '. + [{name: "bot", status: "invalid", method: "token", source: "env"}]')
        fi
      fi
    fi

    _gh_auth=$(jq -n \
      --argjson available "$_can_api" \
      --arg active "$_active" \
      --argjson accounts "$_accounts" \
      '{available: $available, active_account: $active, accounts: $accounts}')
  fi

  echo "$_gh_auth" >"$_tmp/gh_auth"
  echo "$_gh_user" >"$_tmp/gh_user"
  echo "$_can_api" >"$_tmp/gh_can_api"
} &

wait

# ── Collect Phase 1 results ──
_build_code=$(cat "$_tmp/build")
if [[ "$_build_code" == "-1" ]]; then
  BUILD_STATUS="unknown"
elif [[ "$_build_code" == "0" ]]; then
  BUILD_STATUS="pass"
else
  BUILD_STATUS="fail"
fi
UNCOMMITTED_COUNT=$(cat "$_tmp/uncommitted")
WORKTREES=$(cat "$_tmp/worktrees")
SESSION_STATUS=$(cat "$_tmp/linear")
PARALLEL_GROUPS=$(cat "$_tmp/pgroups")
PARALLEL_CHECK=$(cat "$_tmp/pcheck")
GH_AUTH=$(cat "$_tmp/gh_auth")

# ── Phase 2: PR data (depends on GH auth) ──
PR_STATUS_JSON="[]"
REPO_OWNER=""
REPO_NAME=""
GH_CAN_API=$(cat "$_tmp/gh_can_api")
GH_USER=$(cat "$_tmp/gh_user")

if [[ "$GH_CAN_API" == "true" ]] && [[ -n "$GH_USER" ]]; then
  gh pr list --json number,title,headRefName,statusCheckRollup,reviewDecision,reviews 2>/dev/null >"$_tmp/pr_list" &
  gh repo view --json owner,name 2>/dev/null >"$_tmp/repo_info" &
  wait

  # Filter to user's PRs (branch prefix convention: user/branch-name)
  ALL_PRS=$(cat "$_tmp/pr_list" 2>/dev/null |
    jq --arg prefix "$GH_USER/" '[.[] | select(.headRefName | startswith($prefix))]' 2>/dev/null || echo "[]")
  # If no user-prefixed PRs found, show all PRs
  if [[ "$(echo "$ALL_PRS" | jq 'length')" == "0" ]]; then
    ALL_PRS=$(cat "$_tmp/pr_list" 2>/dev/null || echo "[]")
  fi

  PR_STATUS_JSON=$(echo "$ALL_PRS" | jq '[.[] | {
  number: .number,
  title: .title,
  branch: .headRefName,
  review: (
   if .reviewDecision == "APPROVED" then "approved"
   elif .reviewDecision == "CHANGES_REQUESTED" or (.reviews | any(.state == "CHANGES_REQUESTED")) then "changes_requested"
   else "pending"
   end
  ),
  ci: (
   if (.statusCheckRollup | type != "array" or length == 0) then "no_checks"
   elif (.statusCheckRollup | any(.conclusion == "FAILURE")) then "failing"
   elif (.statusCheckRollup | all(.conclusion == "SUCCESS" or .conclusion == "SKIPPED" or .conclusion == "CANCELLED" or .conclusion == null)) then "passing"
   else "pending"
   end
  ),
  checks: (
   if (.statusCheckRollup | type != "array" or length == 0) then "no checks"
   else
    ((.statusCheckRollup | map(select(.conclusion == "SUCCESS")) | length) | tostring) + "/" +
    ((.statusCheckRollup | length) | tostring) + " passed"
   end
  )
  }]' 2>/dev/null || echo "[]")

  REPO_OWNER=$(cat "$_tmp/repo_info" 2>/dev/null | jq -r '.owner.login // empty')
  REPO_NAME=$(cat "$_tmp/repo_info" 2>/dev/null | jq -r '.name // empty')

  # Phase 3: Per-PR enrichment (parallel across PRs)
  PR_NUMS=$(echo "$PR_STATUS_JSON" | jq -r '.[].number')
  if [[ -n "$PR_NUMS" ]] && [[ -n "$REPO_OWNER" ]] && [[ -n "$REPO_NAME" ]] && [[ -x "$GITHUB" ]]; then
    for PR_NUM in $PR_NUMS; do
      {
        if ! _tj=$(json_or_default '{"unresolved_count":0}' object "$GITHUB" pr-threads "$PR_NUM" --unresolved); then
          _tj='{"unresolved_count":0}'
        fi
        if ! _ba=$(json_or_default '{}' object "$GITHUB" sticky-comment "$PR_NUM" --analysis); then
          _ba='{}'
        fi
        echo "$_tj" >"$_tmp/pr_${PR_NUM}_threads"
        echo "$_ba" >"$_tmp/pr_${PR_NUM}_bot"
      } &
    done
    wait

    for PR_NUM in $PR_NUMS; do
      THREADS_JSON=$(cat "$_tmp/pr_${PR_NUM}_threads")
      UNRESOLVED_COUNT=$(echo "$THREADS_JSON" | jq -r '.unresolved_count // 0')
      [[ -z "$UNRESOLVED_COUNT" || "$UNRESOLVED_COUNT" == "null" ]] && UNRESOLVED_COUNT=0

      BOT_ANALYSIS=$(cat "$_tmp/pr_${PR_NUM}_bot")
      BOT_REC=$(echo "$BOT_ANALYSIS" | jq -r '.recommendation // "none"')
      BOT_CAN_MERGE=$(echo "$BOT_ANALYSIS" | jq -r '.can_merge // false')
      REMAINING_ITEM=$(echo "$BOT_ANALYSIS" | jq -r '.remaining_item // ""')

      CI_STATUS=$(echo "$PR_STATUS_JSON" | jq -r ".[] | select(.number == $PR_NUM) | .ci")
      READY_TO_MERGE="false"
      MERGE_REASON=""

      if [[ "$CI_STATUS" == "passing" ]]; then
        if [[ "$BOT_CAN_MERGE" == "true" ]]; then
          if [[ -z "$REMAINING_ITEM" || "$REMAINING_ITEM" == "null" ]]; then
            READY_TO_MERGE="true"
            MERGE_REASON="Bot approves; no remaining items"
          else
            MERGE_REASON="Bot approves; follow-up: $REMAINING_ITEM"
          fi
        elif [[ "$BOT_REC" == "none" ]]; then
          MERGE_REASON="Awaiting bot review"
        else
          MERGE_REASON="Bot requests changes"
        fi
      else
        MERGE_REASON="CI not passing"
      fi

      PR_STATUS_JSON=$(echo "$PR_STATUS_JSON" | jq --argjson num "$PR_NUM" \
        --argjson unresolved "${UNRESOLVED_COUNT:-0}" \
        --arg bot_rec "$BOT_REC" \
        --argjson bot_can_merge "${BOT_CAN_MERGE:-false}" \
        --arg remaining "$REMAINING_ITEM" \
        --argjson ready "$READY_TO_MERGE" \
        --arg reason "$MERGE_REASON" \
        '[.[] | if .number == $num then . + {
     has_unresolved_threads: ($unresolved > 0),
     bot_recommendation: $bot_rec,
     bot_can_merge: $bot_can_merge,
     remaining_item: $remaining,
     ready_to_merge: $ready,
     merge_reason: $reason
    } else . end]')
    done
  fi
fi

# ─────────────────────────────────────────────────────────────────────────────
# Cross-PR Validation (when 2+ PRs ready to merge)
# ─────────────────────────────────────────────────────────────────────────────

CROSS_CHECK='{"status":"skipped","can_batch_merge":false,"issues":[],"merge_order":[],"summary":{"total_prs":0,"issues_count":0,"high_severity":0,"medium_severity":0,"low_severity":0}}'

if [[ -n "$PR_STATUS_JSON" && "$PR_STATUS_JSON" != "[]" ]] && [[ -x "$GITHUB" ]]; then
  READY_COUNT=$(echo "$PR_STATUS_JSON" | jq '[.[] | select(.ready_to_merge == true)] | length')
  if [[ "$READY_COUNT" -gt 1 ]]; then
    READY_NUMS=$(echo "$PR_STATUS_JSON" | jq -r '[.[] | select(.ready_to_merge == true) | .number] | join(" ")')
    READY_ARGV=()
    IFS=' ' read -r -a READY_ARGV <<<"$READY_NUMS"
    if CROSS_CHECK_RAW=$("$GITHUB" pr-cross-check "${READY_ARGV[@]}" --json 2>/dev/null); then
      if jq -e 'type == "object"' >/dev/null 2>&1 <<<"$CROSS_CHECK_RAW"; then
        CROSS_CHECK=$(echo "$CROSS_CHECK_RAW" | jq '. + {status: "ok"}')
      else
        CROSS_CHECK=$(jq -n --argjson ready "$READY_COUNT" '{status: "error", error: "invalid_cross_check_response", can_batch_merge: false, issues: [], merge_order: [], summary: {total_prs: $ready, issues_count: 1, high_severity: 1, medium_severity: 0, low_severity: 0}}')
      fi
    else
      CROSS_CHECK=$(jq -n --argjson ready "$READY_COUNT" '{status: "error", error: "cross_check_failed", can_batch_merge: false, issues: [], merge_order: [], summary: {total_prs: $ready, issues_count: 1, high_severity: 1, medium_severity: 0, low_severity: 0}}')
    fi
  fi
fi

# Issue pattern for extracting IDs from PR titles
_ISSUE_PAT="${ISSUE_PATTERN:-[A-Z]+-[0-9]+}"

# Build final JSON
SESSION_JSON=$(jq -n \
  --arg platform "$PLATFORM" \
  --arg lang "$LANG_NAME" \
  --arg lang_version "$LANG_VERSION" \
  --arg lang_lsp "${LANG_LSP:-}" \
  --arg branch "$BRANCH" \
  --arg build_status "$BUILD_STATUS" \
  --arg repo_owner "${REPO_OWNER:-}" \
  --arg repo_name "${REPO_NAME:-}" \
  --arg issue_pattern "$_ISSUE_PAT" \
  --argjson uncommitted "$UNCOMMITTED_COUNT" \
  --argjson worktrees "$WORKTREES" \
  --argjson gh_auth "$GH_AUTH" \
  --argjson linear "$SESSION_STATUS" \
  --argjson prs "$PR_STATUS_JSON" \
  --argjson cross_check "$CROSS_CHECK" \
  --argjson parallel_groups "$PARALLEL_GROUPS" \
  --argjson parallel_check "$PARALLEL_CHECK" \
  '{
  platform: $platform,
  lang: $lang,
  lang_version: $lang_version,
  lang_lsp: $lang_lsp,
  branch: $branch,
  build_status: $build_status,
  uncommitted: $uncommitted,
  worktrees: $worktrees,
  repo: { owner: $repo_owner, name: $repo_name },
  issue_pattern: $issue_pattern,
  gh_auth: $gh_auth,
  linear: $linear,
  prs: $prs,
  cross_check: $cross_check,
  parallel_groups: $parallel_groups,
  parallel_check: $parallel_check
  }')

# ─────────────────────────────────────────────────────────────────────────────
# Output
# ─────────────────────────────────────────────────────────────────────────────

if [[ "$OUTPUT_FORMAT" == "json" ]]; then
  echo "$SESSION_JSON"
  exit 0
fi

# Check for research findings (scan common research directories)
RESEARCH_WITH_FINDINGS='[]'
if [ -n "$SESSION_JSON" ]; then
  RESEARCH_IDS=$(echo "$SESSION_JSON" | jq -r '[.linear.issues.research_ready[]?, .linear.issues.research_pending[]?] | .[].id')
  if [ -n "$RESEARCH_IDS" ]; then
    FOUND_IDS='[]'
    while IFS= read -r issue_id; do
      [ -z "$issue_id" ] && continue
      # Check common research paths
      for _rdir in "docs/research" "research" "docs/decisions"; do
        if [ -f "$PROJECT_ROOT/$_rdir/$issue_id/findings.md" ]; then
          FOUND_IDS=$(echo "$FOUND_IDS" | jq --arg id "$issue_id" '. + [$id]')
          break
        fi
      done
    done <<<"$RESEARCH_IDS"
    RESEARCH_WITH_FINDINGS="$FOUND_IDS"
  fi
fi

# Dashboard formatter
echo "$SESSION_JSON" | jq -r --argjson findings "$RESEARCH_WITH_FINDINGS" '
# Helper: progress bar (24 chars)
def progress_bar(pct):
  ((pct * 24) | floor) as $filled |
  if $filled < 0 then 0 elif $filled > 24 then 24 else $filled end |
  . as $f | ("█" * $f) + ("░" * (24 - $f));

def pct: (. * 100) | floor;

def clean_agent: if . then gsub("^agent:"; "") else null end;

def status:
  if . == "pass" or . == "passing" or . == "approve" or . == "approved" then "🟢"
  elif . == "fail" or . == "failing" or . == "changes_requested" then "🔴"
  elif . == "pending" then "🟡"
  else "⚠️" end;

def children_tree:
  if .children_progress and (.children_progress.children | length) > 0 then
  [.children_progress.children[] |
   (if .depth == 0 then "   ↳ " elif .depth == 1 then "      ↳ " else "         ↳ " end) +
   "\(.id): \(.title[:45])" +
   (if .agent and .agent != "none" then " [\(.agent)]" else "" end) +
   (if .state_type == "completed" then " ✓" else "" end)
  ] | join("\n")
  else "" end;

def issue_block:
  "\(.url)\n\(.title)\nP\(.priority)\(if .agent | clean_agent then " · Agent: \(.agent | clean_agent)" else "" end)\(if .project_name and .project_name != "" then " · \(.project_name)" else "" end)" +
  (if .children_progress and (.children_progress.children | length) > 0 then "\n\(children_tree)" else "" end) + "\n";

def research_block:
  "\(.url)\n\(.title)\nP\(.priority)" +
  (if .blocks and (.blocks | length) > 0 then " · Blocks: \(.blocks | join(", "))" else "" end) + "\n";

[
  "`Environment ──────────────────────────────────────────────`",
  "\(.platform)\(if .lang != "" then " · \(.lang) \(.lang_version)" else "" end) · \(.branch)\(if .build_status == "pass" then " · 🟢 Build" elif .build_status == "fail" then " · 🔴 Build" else "" end)",
  "GitHub: \(.gh_auth.accounts | map(if .status == "ok" then "✓ \(.name) (\(.method))" else "✗ \(.name) (\(.method))" end) | join(" · "))",
  (if .uncommitted > 0 then "⚠️ \(.uncommitted) uncommitted files" else empty end),
  (if (.gh_auth.accounts | any(.status == "invalid")) then
  "⚠️ gh auth invalid: \(.gh_auth.accounts | map(select(.status == "invalid")) | map(.name) | join(", ")) — run: gh auth logout -u <account>"
  else empty end),
  (if (.worktrees | length) > 0 then
  "⚠️ \(.worktrees | length) active worktrees",
  (.worktrees[] | "   ↳ \(.)")
  else empty end),
  "",

  "`Progress ─────────────────────────────────────────────────`",
  (if (.linear.projects | map(select(.has_active_work)) | length) > 0 then
  (.linear.projects[] | select(.has_active_work) |
   "Project: \(.name)",
   "[\(progress_bar(.progress))]  \(.progress | pct)%",
   (if (.blocks | length) > 0 then
    "→ Unlocks: \([.blocks[].name] | join(", "))"
   else empty end),
   (if (.blocked_by | length) > 0 then
    "🔴 Blocked by: \([.blocked_by[].name] | join(", "))"
   else empty end),
   ""
  )
  else "(no active project with actionable work)" end),

  (if .linear.prev_cycle then
  "Cycle \(.linear.prev_cycle.number): \(.linear.prev_cycle.startsAt[:10]) – \(.linear.prev_cycle.endsAt[:10]) 🟢"
  else empty end),
  (if .linear.cycle then
  "Cycle \(.linear.cycle.number): \(.linear.cycle.startsAt[:10]) – \(.linear.cycle.endsAt[:10])",
  "[\(progress_bar(.linear.cycle.progress))]  \(.linear.cycle.progress | pct)%"
  else "(no cycle)" end),
  "",

  # Research section
  (if (.linear.issues.research_ready | length) > 0 or
   (.linear.issues.research_pending | length) > 0 then
  "`Research ─────────────────────────────────────────────────`",
  (if (.linear.issues.research_ready | length) > 0 then
   "**Ready:**",
   (.linear.issues.research_ready[] | research_block)
  else empty end),
  (if (.linear.issues.research_pending | length) > 0 then
   "**Pending:**",
   (.linear.issues.research_pending[] | research_block)
  else empty end)
  else empty end),

  # In Progress
  (if (.linear.issues.in_progress | length) > 0 then
  "`In Progress ──────────────────────────────────────────────`",
  (.linear.issues.in_progress[] | issue_block)
  else empty end),

  # PRs
  (if (.prs | length) > 0 then
  "`PRs ──────────────────────────────────────────────────────`",
  (. as $root | .prs[] |
   # Extract issue ID from title using configured pattern
   ((.title | capture("\\((?<id>" + $root.issue_pattern + ")\\)") | .id) // "") as $issue_id |
   ([$root.linear.pr_blockers // [] | .[] | select(.parent_id == $issue_id)]) as $blockers |
   [
    "#\(.number) https://github.com/\($root.repo.owner)/\($root.repo.name)/pull/\(.number)",
    .title,
    "Status: \(.ci | status) CI  \(.bot_recommendation | status) Bot  \(if .ready_to_merge then "🟢 Ready" else "🟡 \(.merge_reason)" end)",
    (if .has_unresolved_threads then "⚠️ Unresolved threads" else empty end),
    (if ($blockers | length) > 0 then
     "Pending sub-issues:",
     ($blockers[] | "   ↳ \(.id): \(.title)" + (if (.children | length) > 0 then "\n" + ([.children[] | (if .depth == 0 then "      ↳ " elif .depth == 1 then "         ↳ " else "            ↳ " end) + "\(.id): \(.title[:40])"] | join("\n")) else "" end))
    else empty end),
    ""
   ] | map(select(. != null)) | join("\n")),
  ""
  else empty end),

  # Cross-PR Analysis
  (if (.cross_check.summary.total_prs // 0) > 1 then
  "`Cross-PR Analysis ────────────────────────────────────────`",
  (if (.cross_check.status // "") == "error" then
   "⚠️ Cross-PR analysis unavailable: \(.cross_check.error // "unknown_error")"
  elif (.cross_check.issues | length) == 0 then
   "✓ No conflicts detected between \(.cross_check.summary.total_prs) ready PRs"
  else
   (.cross_check.issues[] |
    "\(if .severity == "high" then "🔴" elif .severity == "medium" then "🟡" else "⚪" end) \(.type): \(.description)")
  end),
  "Merge order: \(.cross_check.merge_order | map("#\(.)") | join(" → "))",
  ""
  else empty end),

  # Up Next (with parallel group visual grouping)
  ([.parallel_groups // [] | .[] | select(.verdict == "conflicts")] | first // null) as $par_conflict |

  ([.linear.issues.actionable[:4][] | .id]) as $top_ids |
  ([.parallel_groups // [] | .[] | select(.verdict == "safe")] |
  [.[] | . as $g | {group: $g, rank: ([$top_ids[] | select(. as $i | $g.issues | index($i))] | if length > 0 then 0 else 999 end)}] |
  [.[] | select(.rank == 0)] |
  [.[] | .group as $g | {group: $g, best: ([$top_ids | to_entries[] | select(.value as $i | $g.issues | index($i))] | min_by(.key) | .key // 999)}] |
  sort_by(.best) | first // null | .group
  ) as $primary_group |
  (if $primary_group then $primary_group.issues else [] end) as $pissues |

  ([.linear.issues.actionable[] | select(.id as $i | $pissues | index($i))]) as $grouped |
  ([.linear.issues.actionable[] |
  if (.id as $i | $pissues | index($i)) then {type: "group", id: .id}
  else {type: "issue", id: .id} end
  ] | reduce .[] as $s (
  {slots: [], group_placed: false};
  if ($s.type == "group") then
   if .group_placed then . else .slots += [{type: "group"}] | .group_placed = true end
  else .slots += [$s] end
  ) | .slots[:4]) as $slots |

  ([.linear.issues.actionable[]?, .linear.issues.blocked[]?, .linear.issues.backlog[]? |
  select(.children_progress and (.children_progress.children | length) > 0)] as $parents |
  {sizes: ([$parents[] | {key: .id, value: (.children_progress.children | length)}] | from_entries),
     c2p: ([$parents[] | .id as $pid | .children_progress.children[] | {key: .id, value: $pid}] | from_entries)}
  ) as $bmap |

  "`Up Next ──────────────────────────────────────────────────`",
  (if ($pissues | length) == 0 and $par_conflict then
  "(\($par_conflict.conflicts | join("; ")))"
  else empty end),
  (if (.linear.issues.actionable | length) == 0 then "(no actionable issues)\n"
  elif ($grouped | length) > 1 then
  (. as $root | $slots[] |
   if .type == "group" then
    "┌── `Parallel group (\($grouped | length))` ───────────────────────────────────",
    ([$grouped[] | issue_block | rtrimstr("\n")] | join("\n\n") | split("\n") | [.[] | if . == "" then "│" else "│ \(.)" end] | join("\n")),
    "└──────────────────────────────────────────────────────────",
    ""
   else
    .id as $sid | ($root.linear.issues.actionable[] | select(.id == $sid) | issue_block)
   end
  )
  else
  (.linear.issues.actionable[:4][] | issue_block)
  end),

  # Recommended action
  "`Recommended ──────────────────────────────────────────────`",
  (
  [.linear.projects[] | select(.has_active_work)] as $active_projects |
  ([.linear.projects[] | select(.progress == 1 and .perpetual != true)] | first // null) as $completed_project |
  ([.linear.projects[] | select((.blocked_by | length) > 0)] | first // null) as $blocked_project |

  if .build_status == "fail" then
   "👉 Fix build errors — blocks all work"
  elif (.prs | map(select(.ci == "failing")) | length) > 0 then
   (.prs | map(select(.ci == "failing"))[0]) as $pr |
   "👉 Fix CI on PR #\($pr.number) — checks failing"
  elif (.prs | map(select(.has_unresolved_threads)) | length) > 0 then
   (.prs | map(select(.has_unresolved_threads))[0]) as $pr |
   "👉 Address feedback on PR #\($pr.number) — unresolved review threads"
  elif (.prs | map(select(.bot_can_merge and .remaining_item != "" and .remaining_item != null)) | length) > 0 then
   (.prs | map(select(.bot_can_merge and .remaining_item != "" and .remaining_item != null))[0]) as $pr |
   "👉 Create issue for \($pr.remaining_item), then merge PR #\($pr.number) — approved, remaining item to track"
  elif (.prs | map(select(.ready_to_merge)) | length) > 1 then
   if (.cross_check.status // "") == "error" then
    "👉 Review ready PRs manually — cross-PR analysis unavailable"
   elif .cross_check.can_batch_merge then
    "👉 Batch merge \(.prs | map(select(.ready_to_merge)) | length) PRs — all approved, no conflicts"
   elif ((.cross_check.merge_order | length) > 0) then
    "👉 Merge PR #\(.cross_check.merge_order[0]) first — merge-order conflict between PRs"
   else
    "👉 Review ready PRs manually — cross-PR analysis found conflicts"
   end
  elif (.prs | map(select(.ready_to_merge)) | length) == 1 then
   (.prs | map(select(.ready_to_merge))[0]) as $pr |
   "👉 Merge PR #\($pr.number) — approved, checks passing"
  elif (.linear.pr_blockers | length) > 0 then
   (.linear.pr_blockers | length) as $subs |
   "👉 Start \(.linear.pr_blockers[0].parent_id) — PR blocked on \($subs) sub-issue\(if $subs > 1 then "s" else "" end)"
  elif ($findings | length) > 0 then
   "👉 Process research for \($findings[0]) — completed research ready to link"
  elif (.linear.research.unprocessed | length) > 0 then
   "👉 Process unprocessed research findings"
  elif $completed_project then
   "👉 Complete \($completed_project.name) — project at 100%"
  elif ($active_projects | length) == 0 then
   "👉 Activate a project — no active project"
  elif $blocked_project then
   "👉 Project blocked by: \([$blocked_project.blocked_by[].name] | join(", "))"
  elif .linear.cycle == null or (.linear.issues.actionable | length) == 0 then
   "👉 Plan cycle — \(if .linear.cycle == null then "no active cycle" else "no actionable issues" end)"
  elif .parallel_check.needed then
   "👉 Run parallel-check for \(.parallel_check.project) — \(.parallel_check.reason // "\(.parallel_check.count) Todo issues uncovered")"
  elif (.linear.issues.actionable | length) > 0 then
   .linear.issues.actionable[0] as $top |
   if $top.children_progress and $top.children_progress.done > 0 then
    "👉 Continue \($top.id): \($top.title[:40]) (\($top.children_progress.done)/\($top.children_progress.total))"
   elif (($pissues | length) > 1) and ($pissues | index($top.id)) then
    "👉 Start in parallel: \([$pissues[] | . as $id | if $bmap.c2p[$id] and ($pissues | index($bmap.c2p[$id])) then empty elif $bmap.sizes[$id] then "\($id) (📦\($bmap.sizes[$id]))" else $id end] | join(", ")) — safe parallel group"
   else
    "👉 Start \($top.id): \($top.title[:40])"
   end
  elif (.linear.issues.blocked | length) > 0 then
   "👉 Review blockers or wait — all issues blocked"
  else
   "👉 No action needed"
  end
  )
] | join("\n")
'
