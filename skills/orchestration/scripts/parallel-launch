#!/usr/bin/env bash
# Launch parallel worktrees for a group of issues.
#
# Usage:
#   parallel-launch <group_id> [--tmux | --ghostty] [--cmd "command {issue}"]
#   parallel-launch ISSUE-1 ISSUE-2 ... [--tmux | --ghostty] [--cmd "command {issue}"]
#
# Options:
#   --cmd "..."    Command to run in each worktree. Use {issue} as placeholder
#                  for the issue ID. If omitted, opens a shell in the worktree.
#   --tmux         Open tmux windows (requires active tmux session)
#   --ghostty      Open Ghostty terminals
#
# Environment:
#   ISSUE_PATTERN  - Regex pattern matching issue IDs (default: "[A-Z]+-[0-9]+")

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Resolve project root, handling worktree paths
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
_git_common_dir=$(git -C "$PROJECT_ROOT" rev-parse --git-common-dir 2>/dev/null || echo "")
if [[ "$_git_common_dir" != ".git" && -n "$_git_common_dir" ]]; then
  PROJECT_ROOT="$(dirname "$_git_common_dir")"
fi
SKILLS_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
ENV_FILE="$PROJECT_ROOT/.env.local"
if [[ -f "$ENV_FILE" ]]; then
  # shellcheck source=/dev/null
  source "$ENV_FILE"
fi

# Resolve WORKTREE_CLI from sibling skill
WORKTREE_CLI="${WORKTREE_CLI:-$SKILLS_DIR/worktree/scripts/worktree}"

# Configurable issue pattern (default: JIRA-style ABC-123)
ISSUE_PATTERN="${ISSUE_PATTERN:-[A-Z]+-[0-9]+}"

TERMINAL_MODE=""
ISSUES=()
GROUP_ID=""
CMD_TEMPLATE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --tmux) TERMINAL_MODE="tmux"; shift ;;
    --ghostty) TERMINAL_MODE="ghostty"; shift ;;
    --cmd) CMD_TEMPLATE="$2"; shift 2 ;;
    --help|-h)
      echo "Usage: parallel-launch <group_id> [--tmux | --ghostty] [--cmd \"command {issue}\"]"
      echo "       parallel-launch ISSUE-1 ISSUE-2 ... [--tmux | --ghostty] [--cmd \"...\"]"
      echo ""
      echo "Options:"
      echo "  --tmux              Open tmux windows (requires active tmux session)"
      echo "  --ghostty           Open Ghostty terminals"
      echo "  --cmd \"command\"     Command to run in each worktree ({issue} is replaced)"
      echo "  (default terminal)  Auto-detect: tmux if \$TMUX set, else ghostty"
      echo ""
      echo "Environment:"
      echo "  ISSUE_PATTERN  Regex for issue IDs (default: [A-Z]+-[0-9]+)"
      exit 0
      ;;
    [0-9]*) GROUP_ID="$1"; shift ;;
    *)
      # Match against configurable issue pattern
      if echo "$1" | grep -qE "^${ISSUE_PATTERN}$"; then
        ISSUES+=("$(echo "$1" | tr '[:lower:]' '[:upper:]')"); shift
      else
        echo "Error: unexpected argument: $1" >&2; exit 1
      fi
      ;;
  esac
done

# Auto-detect terminal mode
if [[ -z "$TERMINAL_MODE" ]]; then
  if [[ -n "${TMUX:-}" ]]; then
    TERMINAL_MODE="tmux"
  else
    TERMINAL_MODE="ghostty"
  fi
fi

# Resolve issues from group_id if no explicit issues
if [[ ${#ISSUES[@]} -eq 0 && -n "$GROUP_ID" ]]; then
  GROUPS_JSON=$("$SCRIPT_DIR/parallel-groups" read 2>/dev/null || echo "[]")
  GROUP_ISSUES=$(echo "$GROUPS_JSON" | jq -r --argjson gid "$GROUP_ID" '.[] | select(.group_id == $gid) | .issues[]' 2>/dev/null)
  if [[ -z "$GROUP_ISSUES" ]]; then
    echo "Error: no active group with id $GROUP_ID (may be stale)" >&2
    exit 1
  fi
  while IFS= read -r issue; do
    ISSUES+=("$issue")
  done <<< "$GROUP_ISSUES"
fi

# Require worktree CLI
if [[ ! -x "$WORKTREE_CLI" ]]; then
  echo "Error: WORKTREE_CLI not found at '$WORKTREE_CLI'. Is the worktree skill installed?" >&2
  exit 1
fi

if [[ ${#ISSUES[@]} -lt 2 ]]; then
  echo "Error: need at least 2 issues to launch in parallel" >&2
  exit 1
fi

echo "Launching ${#ISSUES[@]} parallel worktrees (${TERMINAL_MODE})..."

LAUNCHED=0
FAILED=()

for ISSUE in "${ISSUES[@]}"; do
  echo "  Creating worktree for $ISSUE..."
  if ! WT_PATH=$("$WORKTREE_CLI" create "$ISSUE" 2>&1); then
    echo "  Failed: $WT_PATH" >&2
    FAILED+=("$ISSUE")
    continue
  fi

  # Build start command: explicit --cmd template, or auto-detect harness from install path
  START_CMD=""
  if [[ -n "$CMD_TEMPLATE" ]]; then
    START_CMD="${CMD_TEMPLATE//\{issue\}/$ISSUE}"
  else
    case "$SCRIPT_DIR" in
      */.agents/*)
        START_CMD="codex '\$orchestration start $ISSUE'"
        ;;
      */.opencode/*)
        START_CMD="opencode '/orchestration start $ISSUE'"
        ;;
      */.claude/*)
        START_CMD="claude -n \"$ISSUE\" '/orchestration start $ISSUE'"
        ;;
    esac
  fi

  CMD_ARGS=()
  [[ -n "$START_CMD" ]] && CMD_ARGS=(--cmd "$START_CMD")

  if [[ "$TERMINAL_MODE" == "tmux" ]]; then
    "$SCRIPT_DIR/open-terminal" "$WT_PATH" --tmux "$ISSUE" --title "$ISSUE" "${CMD_ARGS[@]}"
  else
    "$SCRIPT_DIR/open-terminal" "$WT_PATH" --title "$ISSUE" "${CMD_ARGS[@]}"
  fi
  LAUNCHED=$((LAUNCHED + 1))
done

if [[ ${#FAILED[@]} -gt 0 ]]; then
  echo "Launched $LAUNCHED, failed ${#FAILED[@]}: ${FAILED[*]}" >&2
  exit 1
fi

echo "Done — $LAUNCHED worktrees launched."
