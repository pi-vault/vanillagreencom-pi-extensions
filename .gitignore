# Harness install/runtime mirrors; canonical source lives elsewhere.
# Match files, directories, and symlinks so worktree links stay invisible.
/.agents
/.agents/**
/.claude
/.claude/**
/.cursor
/.cursor/**
/.codex
/.codex/**
/.opencode
/.opencode/**
/.pi
/.pi/**
/opencode.json

# npm artifacts (pi-extensions are published to npm)
node_modules/
*.tgz
npm-debug.log*
yarn-error.log
.pnpm-debug.log

# Stray tsc emit next to pi-extension TS sources (Pi loads .ts directly).
# Intentional bundles (pi-claude-bridge/bundle, pi-session-bridge/bin) are
# whitelisted below.
pi-extensions/*/extensions/**/*.js
pi-extensions/*/extensions/**/*.js.map
pi-extensions/*/extensions/**/*.d.ts
!pi-extensions/pi-claude-bridge/bundle/**
!pi-extensions/pi-session-bridge/bin/**

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*.swo

# Local vstack install state (per-checkout absolute paths; do not commit)
.vstack-lock.json
