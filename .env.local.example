# Copy this file to `.env.local` in your project root and keep only the variables your project actually uses uncommented.
#
# Each variable is grouped by:
# - Used by: which portable skills/workflows read it
# - Set to: what kind of value to provide
#
# Skill script paths (.agents/skills/<name>/scripts/...) are resolved automatically
# by each skill. This file only contains runtime configuration that varies per project.
#
# `skills/worktree` reads this file from the main checkout. Include `.env.local`
# in `WORKTREE_SYMLINKS` when worktree sessions should use the same local config.

# ═══════════════════════════════════════════
# WORKTREE / SHARED WORKFLOW PATHS
# ═══════════════════════════════════════════

WORKTREE_DEFAULT_BRANCH="main"
# Used by: worktree, linear-orch
# Set to: your repo's main integration branch if auto-detection is not reliable.

WORKTREE_BASE_DIR="../trees"
# Used by: worktree
# Set to: parent directory for created worktrees. Relative paths resolve from the main
# checkout; absolute paths are used as-is. Default behavior is sibling `../trees`.

WORKTREE_SYMLINKS=".env.local opencode.json .agents .cursor .codex .opencode .pi .claude/settings.json .claude/agents .claude/hooks .claude/skills"
# Used by: worktree
# Set to: space-separated project-relative paths that should stay shared across worktrees.
# Keep `.claude` itself as a real worktree directory when relative links inside it
# need to resolve to worktree-local files.

WORKTREE_RELATIVE_SYMLINKS=".claude/CLAUDE.md=../AGENTS.md .claude/AGENTS.md=../AGENTS.md"
# Used by: worktree
# Set to: space-separated `path=target` symlinks created inside each worktree.
# Relative targets resolve from the link location inside the worktree.

WORKTREE_COPIES=".vstack-lock.json"
# Used by: worktree
# Set to: space-separated project-relative files that should be copied into each worktree.

WORKTREE_MKDIRS="tmp"
# Used by: worktree
# Set to: space-separated project-relative paths to `mkdir -p` inside each worktree.
# Intended for gitignored scratch dirs (e.g. `tmp` for agent task briefs, intermediate result
# JSONs, and review hand-offs). Listed dirs must already be covered by `.gitignore` if you
# don't want them committed.

ORCH_STATE_DIR="tmp"
# Used by: linear-orch
# Set to: an alternate directory for persisted linear-orch workflow state.

ORCH_CACHE_DIR=".cache/orchestration"
# Used by: flightdeck (`parallel-groups`) — variable name retained for backwards compat with consumer .env.local files
# Set to: an alternate directory for the parallel-group safety cache.


# ═══════════════════════════════════════════
# BOT / COMMIT IDENTITY
# ═══════════════════════════════════════════

BOT_NAME="automation-bot"
# Used by: worktree
# Set to: the git user.name to use inside bot-created worktrees.

BOT_EMAIL="you+bot@example.com"
# Used by: worktree
# Set to: the git user.email to use inside bot-created worktrees.

BOT_SIGNING_KEY="ssh-ed25519 AAAA..."
# Used by: worktree
# Set to: an optional SSH signing key for commits made inside worktrees.

BOT_REMOTE_NAME="bot-remote"
# Used by: worktree
# Set to: the git remote name to use for bot pushes.

BOT_REMOTE_URL="git@github-bot:org/repo.git"
# Used by: worktree
# Set to: the git remote URL to add to worktrees when bot pushes should use a separate remote.

BOT_REVIEWERS="review-bot-a[bot],review-bot-b[bot]"
# Used by: github, linear-orch
# Set to: comma-separated review bot usernames when review waiting should not rely on auto-detection.

BOT_CHECK_NAME="review-bot"
# Used by: linear-orch (`bot-review-wait`)
# Set to: an optional CI check name that signals bot review progress early.

# ═══════════════════════════════════════════
# DECIDER
# ═══════════════════════════════════════════

DECISIONS_DIR="docs/decisions"
# Used by: decider
# Set to: path to your decision documents directory (contains INDEX.md).
# Auto-discovers docs/decisions/, decisions/, doc/decisions/, or adr/ if not set.

# ═══════════════════════════════════════════
# LINEAR
# ═══════════════════════════════════════════

LINEAR_API_KEY="lin_api_..."
# Used by: linear
# Set to: a Linear personal API key from Linear Settings -> API.

LINEAR_TEAM="MyTeam"
# Used by: linear
# Set to: the default Linear team name your issue commands should target.

LINEAR_FORMAT="safe"
# Used by: linear
# Set to: the default output format for the Linear CLI (`safe`, `table`, `ids`, or `raw`).

LINEAR_TEAM_PREFIX="PROJ"
# Used by: linear
# Set to: the issue ID prefix used by your team, such as `PROJ` for `PROJ-123`.

# ═══════════════════════════════════════════
# GITHUB
# ═══════════════════════════════════════════

GH_BOT_TOKEN="ghp_..."
# Used by: github
# Set to: a GitHub token for bot PR/comment/review actions.
# Can also be a 1Password reference if your environment provides `op`.

GH_BOT_USERNAME="automation[bot]"
# Used by: github
# Set to: the GitHub login that should be treated as the review/comment bot.

GH_ISSUE_PATTERN="[A-Z]+-[0-9]+"
# Used by: github, linear-orch
# Set to: the regex used to extract issue IDs from branch names.

GH_VERIFY_CMD="make verify"
# Used by: github (`pr-cross-check --verify`)
# Set to: the command that should run for full verification if auto-detection is not enough.

# ═══════════════════════════════════════════
# DEEP RESEARCH / WEB TOOLS
# ═══════════════════════════════════════════

EXA_API_KEY="exa_..."
# Used by: deep-research, pi-web-tools
# Set to: an Exa API key for Exa Search and Exa Deep Search. Required for
# researcher-owned findings reports and `web_research`.
# Supports direct keys and 1Password references such as:
# EXA_API_KEY="op://Private/Exa API Key/credential"

PERPLEXITY_API_KEY="pplx_..."
# Used by: pi-web-tools (`web_search provider=perplexity`)
# Set to: a Perplexity API key for Sonar models. Optional — only needed if
# you want to route web_search through Perplexity.
# Supports direct keys and 1Password references.

GEMINI_API_KEY="AIza..."
# Used by: pi-web-tools (`web_search provider=gemini`, YouTube + local video understanding)
# Set to: a Google AI Studio API key with access to gemini-2.5-flash or similar.
# Optional — only needed for the Gemini API path. Gemini Web (browser cookies)
# is a separate opt-in via `pi-web-tools.browserCookieAccess`.
# Supports direct keys and 1Password references.

JINA_API_KEY="jina_..."
# Used by: pi-web-tools (Jina Reader fallback in HTML extraction)
# Set to: an optional Jina API key for higher-rate-limit access to https://r.jina.ai.
# Optional — anonymous access works without a key but may rate-limit on heavy usage.

OPENAI_API_KEY="sk-..."
# Used by: pi-codex-minimal-tools (direct image_generation fallback), pi-web-tools
# Set to: an OpenAI API key. Optional — only needed for direct OpenAI provider/API paths,
# such as direct image generation when native Codex image_generation is unavailable.
# Supports direct keys and 1Password references.

# ═══════════════════════════════════════════
# FLIGHTDECK
# ═══════════════════════════════════════════

FLIGHTDECK_POLL_INTERVAL="30"
# Used by: flightdeck
# Set to: seconds between poll cycles in the master watch loop.

FLIGHTDECK_FORCE_MERGE_AFTER_SECS="240"
# Used by: flightdeck
# Set to: seconds a PR must remain in mergeStateStatus=UNKNOWN before flightdeck
# considers force-merging (predicate also requires APPROVED + green + content-disjoint).

FLIGHTDECK_STATE_DIR="tmp"
# Used by: flightdeck
# Set to: an alternate directory for the persisted master-state file
# (`flightdeck-state-<TMUX_SESSION>.json`).

FLIGHTDECK_DEBOUNCE_CYCLES="2"
# Used by: flightdeck
# Set to: consecutive poll cycles required for the "all-done" termination check.


# ═══════════════════════════════════════════
# SECOND OPINION
# ═══════════════════════════════════════════

SECOND_OPINION_TARGET="codex"
# Used by: second-opinion
# Set to: force a specific target CLI instead of auto-detection. Values: claude | codex

SECOND_OPINION_TIMEOUT="600"
# Used by: second-opinion
# Set to: max seconds to wait for the external CLI response.

SECOND_OPINION_CLAUDE_CMD="claude -p --no-session-persistence --model opus --effort max --allowedTools Bash(read-only:true),Read,Glob,Grep"
# Used by: second-opinion (when calling Claude from Codex)
# Set to: the full claude command with all flags. Edit model, effort, or allowed tools here.
#   -p                         Print mode (non-interactive, single response)
#   --no-session-persistence   Don't save session to disk
#   --model opus               Claude Opus 4.6
#   --effort max               Maximum reasoning effort
#   --allowedTools ...         Read-only bash, file reads, search — no writes

SECOND_OPINION_CODEX_CMD="codex exec -m gpt-5.4 -s read-only -c model_reasoning_effort=xhigh --ephemeral"
# Used by: second-opinion (when calling Codex from Claude)
# Set to: the full codex command with all flags. Edit model, reasoning effort, or sandbox here.
#   exec                               Non-interactive execution mode
#   -m gpt-5.4                         GPT-5.4 model
#   -s read-only                       Read-only sandbox (no file modifications)
#   -c model_reasoning_effort=xhigh    Maximum reasoning effort
#   --ephemeral                        Don't persist session to disk

# ═══════════════════════════════════════════
# DEBUG / OVERRIDE HOOKS
# ═══════════════════════════════════════════
# These are implementation-detail escape hatches. Normal projects don't need to set them —
# scripts auto-resolve to sibling skill paths. Override only when debugging or running
# alternate skill installations.

WORKTREE_CLI=".agents/skills/worktree/scripts/worktree"
# Used by: linear-orch (`open-terminal`)
# Set to: override the path to the worktree skill's CLI.

GIT_HOST_CLI=".agents/skills/github/scripts/github.sh"
# Used by: linear-orch (`bot-review-wait`, `ci-wait`)
# Set to: override the path to the github skill's CLI.