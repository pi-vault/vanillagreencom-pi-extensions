# Copy this file to `.env.local` in your project root and keep only the variables your project actually uses uncommented.
#
# Each variable is grouped by:
# - Used by: which portable skills/workflows read it
# - Set to: what kind of value to provide
#
# Skill script paths (.agents/skills/<name>/scripts/...) are resolved automatically
# by each skill. This file only contains runtime configuration that varies per project.
#
# `skills/worktree` symlinks `.env.local` into worktrees, so these settings stay available in delegated sessions.

# ═══════════════════════════════════════════
# WORKTREE / SHARED WORKFLOW PATHS
# ═══════════════════════════════════════════

WORKTREE_DEFAULT_BRANCH="main"
# Used by: worktree, orchestration
# Set to: your repo's main integration branch if auto-detection is not reliable.

WORKTREE_SYMLINKS=".cache benchmarks/results"
# Used by: worktree
# Set to: space-separated project-relative paths that should stay shared across worktrees.

WORKTREE_COPIES=".tooling/settings.json"
# Used by: worktree
# Set to: space-separated project-relative files that should be copied into each worktree.

ORCH_STATE_DIR="tmp"
# Used by: orchestration
# Set to: an alternate directory for persisted orchestration workflow state.


# ═══════════════════════════════════════════
# BOT / COMMIT IDENTITY
# ═══════════════════════════════════════════

BOT_NAME="automation-bot"
# Used by: worktree
# Set to: the git user.name to use inside bot-created worktrees.

BOT_EMAIL="you+bot@example.com"
# Used by: worktree
# Set to: the git user.email to use inside bot-created worktrees.

BOT_SIGNING_KEY="ssh-ed25519 AAAA..."
# Used by: worktree
# Set to: an optional SSH signing key for commits made inside worktrees.

BOT_REMOTE_NAME="bot-remote"
# Used by: worktree
# Set to: the git remote name to use for bot pushes.

BOT_REMOTE_URL="git@github-bot:org/repo.git"
# Used by: worktree
# Set to: the git remote URL to add to worktrees when bot pushes should use a separate remote.

BOT_REVIEWERS="review-bot-a[bot],review-bot-b[bot]"
# Used by: github, orchestration
# Set to: comma-separated review bot usernames when review waiting should not rely on auto-detection.

BOT_CHECK_NAME="review-bot"
# Used by: orchestration (`bot-review-wait`)
# Set to: an optional CI check name that signals bot review progress early.

# ═══════════════════════════════════════════
# DECIDER
# ═══════════════════════════════════════════

DECISIONS_DIR="docs/decisions"
# Used by: decider
# Set to: path to your decision documents directory (contains INDEX.md).
# Auto-discovers docs/decisions/, decisions/, doc/decisions/, or adr/ if not set.

# ═══════════════════════════════════════════
# LINEAR
# ═══════════════════════════════════════════

LINEAR_API_KEY="lin_api_..."
# Used by: linear
# Set to: a Linear personal API key from Linear Settings -> API.

LINEAR_TEAM="MyTeam"
# Used by: linear
# Set to: the default Linear team name your issue commands should target.

LINEAR_FORMAT="safe"
# Used by: linear
# Set to: the default output format for the Linear CLI (`safe`, `table`, `ids`, or `raw`).

LINEAR_TEAM_PREFIX="PROJ"
# Used by: linear
# Set to: the issue ID prefix used by your team, such as `PROJ` for `PROJ-123`.

# ═══════════════════════════════════════════
# GITHUB
# ═══════════════════════════════════════════

GH_BOT_TOKEN="ghp_..."
# Used by: github
# Set to: a GitHub token for bot PR/comment/review actions.
# Can also be a 1Password reference if your environment provides `op`.

GH_BOT_USERNAME="automation[bot]"
# Used by: github
# Set to: the GitHub login that should be treated as the review/comment bot.

GH_ISSUE_PATTERN="[A-Z]+-[0-9]+"
# Used by: github, orchestration
# Set to: the regex used to extract issue IDs from branch names.

GH_VERIFY_CMD="make verify"
# Used by: github (`pr-cross-check --verify`)
# Set to: the command that should run for full verification if auto-detection is not enough.